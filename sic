function uploadDocForVehicle(targa) {
  var inp = document.createElement('input');
  inp.type = 'file';
  inp.accept = '.pdf';
  inp.onchange = function(e) {
    var f = e.target.files[0];
    if (!f) return;
    var r2 = new FileReader();
    r2.onload = function(ev) {
      var v = findVehicle(targa);
      if (!v) return;
      if (!v.docs) v.docs = [];
      v.docs.push({ name: f.name, date: new Date().toISOString().slice(0,10), data: ev.target.result });
      saveFleet();
      showToast('✅ Documento caricato');
      openDocsModal(targa);
    };
    r2.readAsDataURL(f);
  };
  inp.click();
}

