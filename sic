function resetDatabase() {
  if (!confirm('⚠️ ATTENZIONE: Cancellare TUTTI i dati del DB (flotta, cancellate, CID, prenotazioni)?\n\nQuesta operazione è irreversibile!')) return;
  if (!confirm('Sei sicuro? Tutti i dati verranno persi definitivamente.')) return;
  FLEET = [];
  cancelledFleet = [];
  CID_LIST = [];
  runtime = {};
  var keys = [];
  for (var k in localStorage) { if (k.indexOf('mf_') === 0 || k.indexOf('myfleet') === 0) keys.push(k); }
  keys.forEach(function(k) { localStorage.removeItem(k); });
  saveFleet();
  renderStats();
  renderList();
  closeAll();
  showToast('✓ DB resettato. Importa un nuovo Excel.');
}

