function cdbSalva() {
  // [V43] Bloomoove entity lock applicato anche al salvataggio rapido
  var cid     = document.getElementById('cdbCid').value.trim();
  var cognome = document.getElementById('cdbCognome').value.trim();
  var nome    = document.getElementById('cdbNome').value.trim();
  var mail    = document.getElementById('cdbMail').value.trim();
  var sede    = document.getElementById('cdbSede').value.trim();
  var targa   = document.getElementById('cdbTarga').value.trim().toUpperCase();
  var ruolo   = document.getElementById('cdbRuolo').value;

  if (!cid || !cognome || !nome) { showToast('⚠️ CID, Cognome e Nome sono obbligatori', true); return; }
  if (cid !== '1234' && !cid.startsWith('084')) { showToast('⚠️ CID non valido: deve iniziare con 084', true); return; }

  var existing = -1;
  for (var i = 0; i < CID_LIST.length; i++) { if (CID_LIST[i].cid === cid) { existing = i; break; } }
  var entry = { cid: cid, cognome: cognome, nome: nome, mail: mail||null, sede: sede||null, targa: targa||null, ruolo: ruolo||'Assegnatario' };
  if (existing >= 0) { CID_LIST[existing] = entry; showToast('✅ Anagrafica aggiornata: ' + cid); }
  else { CID_LIST.push(entry); showToast('✅ Anagrafica aggiunta: ' + cid); }

  localStorage.setItem('mf_cid_list', JSON.stringify(CID_LIST));

  renderCidTable();
  cdbReset();
}

