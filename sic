function doLogin() {
  var cid = document.getElementById('loginCid').value.trim();
  var pin = document.getElementById('loginPin').value.trim();
  var err = document.getElementById('loginErr');
  err.textContent = '';
  if (!cid) { err.textContent = 'Inserisci il CID'; return; }
  if (!pin) { err.textContent = 'Inserisci il PIN'; return; }

  // Normalizza CID: accetta con o senza zero iniziale
  var cidNorm = cid.replace(/^0+/, '');

  // helper: confronta due CID ignorando zero iniziale
  function sameCid(a, b) {
    if (!a || !b) return false;
    return a.replace(/^0+/,'') === b.replace(/^0+/,'');
  }

  // 1. Super Admin hardcoded (CID 1234)
  if (cid === '1234' && pin === SUPERADMIN_PIN) {
    currentUser = { cid:'1234', nome:'Super Admin', cognome:'', isAdmin:true, isGuest:false, isSuperAdmin:true, ruolo:'Admin' };
    saveSession(currentUser); postLoginFlow(); return;
  }

  // 2. Admin CID da lista hardcoded
  var isAdminCid = ADMIN_CIDS.some(function(a){ return sameCid(a, cid); });
  if (isAdminCid) {
    if (pin !== COMPANY_PIN) { err.textContent = 'PIN non corretto'; return; }
    currentUser = { cid:cid, nome:'Amministratore', cognome:'', isAdmin:true, isGuest:false, ruolo:'Admin' };
    saveSession(currentUser); postLoginFlow(); return;
  }

  // 3. PIN ospite manuale
  if (pin === GUEST_PIN) {
    // VALIDAZIONE CID ospite: deve iniziare con 084 e avere esattamente 8 cifre
    if (!/^084\d{5}$/.test(cid)) {
      err.textContent = 'CID non valido. Deve iniziare con 084 e avere 8 cifre (es. 08401234)';
      return;
    }
    showGuestRegistration(cid);
    return;
  }

  // 4. PIN aziendale: tutti i dipendenti
  if (pin === COMPANY_PIN) {

    // STEP A: cerca CID in CID_anagrafica (importata da Excel)
    // CID_LIST = [{cid, cognome, nome, ruolo, ...}]
    // Col H dell'Excel = ruolo reale (Assegnatario/Ospite/Driver Aut./Gestore Op.)
    // Se col H è vuota -> Assegnatario
    var entry = null;
    for (var i = 0; i < CID_LIST.length; i++) {
      if (sameCid(CID_LIST[i].cid, cid)) { entry = CID_LIST[i]; break; }
    }

    if (entry) {
      var ruolo = entry.ruolo || 'Assegnatario';
      if (ruolo === 'Admin') ruolo = 'Assegnatario'; // sicurezza: Admin solo da ADMIN_CIDS
      currentUser = {
        cid:         entry.cid,
        nome:        entry.nome    || '',
        cognome:     entry.cognome || '',
        isAdmin:     false,
        isGuest:     ruolo === 'Ospite',
        isGestoreOp: ruolo === 'Gestore Op.',
        ruolo:       ruolo
      };
      saveSession(currentUser); postLoginFlow(); return;
    }

    // STEP B: CID_LIST vuota (Excel non importato) — cerca in DB veicoli
    var veicolo = null;
    for (var j = 0; j < FLEET.length; j++) {
      // Cerca per CID display o per _assegnatario_cid (veicolo assegnato temporaneamente in pool)
      if (sameCid(FLEET[j].cid, cid) || sameCid(FLEET[j]._assegnatario_cid, cid)) {
        veicolo = FLEET[j]; break;
      }
    }

    if (veicolo) {
      currentUser = {
        cid:         cid,
        nome:        veicolo._assegnatario_nome  || veicolo.nome    || '',
        cognome:     veicolo._assegnatario_cognome || veicolo.cognome || '',
        isAdmin:     false,
        isGuest:     false,
        isGestoreOp: false,
        ruolo:       'Assegnatario'
      };
      saveSession(currentUser); postLoginFlow(); return;
    }

    // STEP C: né CID_LIST né FLEET hanno questo CID
    // Accade solo se Excel non è stato importato
    // Accettiamo comunque: l'utente conosce il PIN aziendale
    currentUser = {
      cid:         cid,
      nome:        '',
      cognome:     '',
      isAdmin:     false,
      isGuest:     false,
      isGestoreOp: false,
      ruolo:       'Assegnatario'
    };
    saveSession(currentUser); postLoginFlow(); return;
  }

  err.textContent = 'PIN non corretto';
}
