function sendReport(type) {
  var v = curVehicle, seg = nextSeg();

  // Raccoglie i dati dal form corrispondente al tipo
  var nome, desc, off, bl, luogo, data;
  if (type === 'tagliando') {
    nome = document.getElementById('tagliandoNome').value.trim();
    off  = document.getElementById('tagliandoOfficina').value.trim();
    if (!nome) { showToast('Inserisci il tuo nome', true); return; }
    if (!selectedScorta) { showToast('Seleziona una sostitutiva', true); return; }
  } else if (type === 'guasto') {
    nome = document.getElementById('guastoNome').value.trim();
    desc = document.getElementById('guastoDesc').value.trim();
    bl   = document.getElementById('guastoBloccante').value;
    if (!nome || !desc || !bl) { showToast('Compila tutti i campi', true); return; }
  } else if (type === 'incidente') {
    nome  = document.getElementById('incNome').value.trim();
    desc  = document.getElementById('incDesc').value.trim();
    luogo = document.getElementById('incLuogo').value.trim();
    bl    = document.getElementById('incBloccante').value;
    data  = document.getElementById('incData').value;
    if (!nome || !desc || !bl) { showToast('Compila tutti i campi obbligatori', true); return; }
  }

  // Costruisce subject e body in base al tipo
  var subject, body;
  if (type === 'tagliando') {
    subject = '[' + seg + '] TAGLIANDO - ' + v.targa + ' - ' + v.sede;
    body = 'N. SEGNALAZIONE: ' + seg + '\nTAGLIANDO\n====================================\nAuto: ' + v.targa + '\nVeicolo: ' + (v.tipo || '') + '\nSede: ' + v.sede + '\nSegnalato da: ' + nome + '\n';
    if (off) body += 'Officina: ' + off + '\n';
    body += '\nSOSTITUTIVA: ' + selectedScorta.targa + ' - ' + (selectedScorta.tipo || '') + '\nData/Ora: ' + new Date().toLocaleString('it-IT');
  } else if (type === 'guasto') {
    var tipoGuasto = bl === 'si' ? 'BLOCCANTE' : 'NON BLOCCANTE';
    subject = '[' + seg + '] GUASTO ' + tipoGuasto + ' - ' + v.targa + ' - ' + v.sede;
    body = 'N. SEGNALAZIONE: ' + seg + '\nGUASTO\n====================================\nTarga: ' + v.targa + '\nVeicolo: ' + (v.tipo || '') + '\nSede: ' + v.sede + '\nBloccante: ' + (bl === 'si' ? 'SI' : 'NO') + '\nSegnalato da: ' + nome + '\nDescrizione: ' + desc + '\n';
  } else if (type === 'incidente') {
    var tipoInc = bl === 'si' ? 'BLOCCANTE' : 'NON BLOCCANTE';
    subject = '[' + seg + '] INCIDENTE ' + tipoInc + ' - ' + v.targa + ' - ' + v.sede;
    body = 'N. SEGNALAZIONE: ' + seg + '\nINCIDENTE (' + tipoInc + ')\n====================================\nTarga: ' + v.targa + '\nVeicolo: ' + (v.tipo || '') + '\nSede: ' + v.sede + '\nSegnalato da: ' + nome + '\nData/Ora: ' + (data ? new Date(data).toLocaleString('it-IT') : 'N/D') + '\nLuogo: ' + (luogo || 'N/D') + '\n';
    if (gpsCoords) body += 'GPS: ' + gpsCoords.lat + ', ' + gpsCoords.lng + '\nMaps: https://maps.google.com/?q=' + gpsCoords.lat + ',' + gpsCoords.lng + '\n';
    body += '\nDinamica:\n' + desc + '\n';
  }

  // Aggiorna lo stato runtime se bloccante e gestisce sostitutiva/referente nel body
  if (!runtime[v.targa]) runtime[v.targa] = {};
  var bloccante = (type === 'tagliando') || (bl === 'si');
  if (bloccante) {
    runtime[v.targa].stato = 'Officina';
    saveOLS(v.targa);
    // Per incidente: aggiungi AZIONE Leasys prima della sostitutiva (come nel V22)
    if (type === 'incidente') body += '\nAZIONE: Chiamare Leasys 800 959 950\n';
  }

  // Gestisce la sostitutiva
  var userCidLocal = currentUser ? currentUser.cid : '';
  if (selectedScorta && bloccante) {
    if (!runtime[selectedScorta.targa]) runtime[selectedScorta.targa] = {};
    runtime[selectedScorta.targa].stato = null;
    runtime[selectedScorta.targa].assegnato_a = { nome: nome, cognome: currentUser ? currentUser.cognome : '', cid: userCidLocal };
    runtime[selectedScorta.targa].rilasciato = false;
    if (userCidLocal) saveSostitutiva(userCidLocal, selectedScorta.targa, v.targa);
    body += (type === 'tagliando' ? '\nSOSTITUTIVA: ' : 'SOSTITUTIVA: ') + selectedScorta.targa + (type === 'tagliando' ? ' - ' + (selectedScorta.tipo || '') : '') + '\n';
  }

  // Aggiunge info specifiche al body
  if (type === 'guasto') {
    body += '\nAZIONE: Compilare il DEN\nData/Ora: ' + new Date().toLocaleString('it-IT');
  } else if (type === 'incidente') {
    if (bloccante) {
      var ref = getReferente(v.sede);
      if (ref && !selectedScorta) body += 'REFERENTE: ' + ref.nome + ' - ' + ref.tel + '\n';
    } else {
      body += '\nAZIONE: Compilare il DEN\n';
    }
    body += '\nData/Ora invio: ' + new Date().toLocaleString('it-IT');
  }

  sendEmail(subject, body, function() {
    saveFleet();
    closeAll();
    if (type === 'tagliando') {
      showConferma('Tagliando registrato', v.targa + ' in officina. Sostitutiva: ' + selectedScorta.targa + '.');
      var pins = getPinHtml(selectedScorta);
      if (pins) setTimeout(function() { showOverlay('ovPinConferma'); document.getElementById('pinConfermaTitle').textContent = selectedScorta.targa; document.getElementById('pinConfermaContent').innerHTML = pins; }, 500);
    } else if (type === 'guasto') {
      showConferma('Guasto registrato', 'Ricordati di compilare il DEN.');
    } else if (type === 'incidente') {
      showConferma('Incidente registrato', 'Segnalazione inviata.');
    }
  }, v.sede);
}
