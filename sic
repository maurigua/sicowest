// ── Fetch parallelo di tutti gli 8 fogli ──────────────────────────────
// Strategia: prova fetch diretto; se fallisce (file://, CORS, rete),
// ritenta via allorigins.win che aggira il blocco CORS su file://.
async function fetchGoogleSheetCompleto() {
  var tabs = [
    { nome: 'VEICOLI',            key: 'VEICOLI' },
    { nome: 'PERSONE',            key: 'PERSONE' },
    { nome: 'ASSEGNAZIONI',       key: 'ASSEGNAZIONI' },
    { nome: 'UTILIZZI',           key: 'UTILIZZI' },
    { nome: 'EASYPARK',           key: 'EASYPARK' },
    { nome: 'ZTL',                key: 'ZTL' },
    { nome: 'NOTE_OPERATIVE',     key: 'NOTE_OPERATIVE' },
    { nome: 'TARGHE_CANCELLATE',  key: 'TARGHE_CANCELLATE' }
  ];
  var risultato = {};

  // Parser comune per la risposta gviz JSON
  function parseGvizText(text) {
    var s = text.indexOf('{'), e = text.lastIndexOf('}');
    if (s < 0 || e < 0) return [];
    var j;
    try { j = JSON.parse(text.substring(s, e + 1)); } catch(ex) { return []; }
    if (!j.table || !j.table.rows) return [];
    var hdrs = j.table.cols.map(function(c){ return (c.label || c.id || '').trim(); });
    return j.table.rows.filter(function(row){ return row && row.c; }).map(function(row) {
      var obj = {};
      row.c.forEach(function(cell, i) {
        if (hdrs[i]) obj[hdrs[i]] = cell ? (cell.f !== undefined && cell.f !== null ? cell.f :
          (cell.v !== null && cell.v !== undefined ? String(cell.v) : '')) : '';
      });
      return obj;
    }).filter(function(obj){ return Object.values(obj).some(function(v){ return v !== ''; }); });
  }

  function fetchSingoloFoglio(nomeFoglio) {
    var gvizUrl = 'https://docs.google.com/spreadsheets/d/' + GSHEETS_ID_4NF +
                  '/gviz/tq?tqx=out:json&sheet=' + encodeURIComponent(nomeFoglio);

    // Tentativo 1: fetch diretto (funziona da Chrome/Android con rete)
    return fetch(gvizUrl, { cache: 'no-store' })
      .then(function(r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.text().then(function(t) {
          var rows = parseGvizText(t);
          if (!rows.length) throw new Error('empty');
          return rows;
        });
      })
      .catch(function() {
        // Tentativo 2: proxy allorigins (funziona da file:// Windows)
        var proxyUrl = 'https://api.allorigins.win/raw?url=' + encodeURIComponent(gvizUrl);
        return fetch(proxyUrl, { cache: 'no-store' })
          .then(function(r) {
            if (!r.ok) throw new Error('proxy HTTP ' + r.status);
            return r.text();
          })
          .then(function(t) {
            return parseGvizText(t);
          });
      });
  }

  var promises = tabs.map(function(tab) {
    return fetchSingoloFoglio(tab.nome).then(function(dati) {
      risultato[tab.key] = dati;
    }).catch(function(err) {
      console.warn('[V42] Foglio', tab.nome, 'non disponibile:', err.message);
      risultato[tab.key] = [];
    });
  });
  await Promise.all(promises);
  if (!risultato.VEICOLI || risultato.VEICOLI.length === 0) throw new Error('Foglio VEICOLI vuoto');
  return risultato;
}

// ── Caricamento principale: cloud → cache → boot ──────────────────────
async function caricaDatiDaCloud() {
  var statusDiv = document.getElementById('homeDbStatus');
  if (statusDiv) { statusDiv.innerHTML = '🔄 Sincronizzazione cloud...'; statusDiv.style.color = '#fbbf24'; }
  try {
    var dati = await fetchGoogleSheetCompleto();
    if (dati && dati.VEICOLI && dati.VEICOLI.length > 0) {
      applicaDatiFlotta(dati);
      localStorage.setItem('mf_last_sync_success', new Date().toISOString());
      // Salva SOLO il raw — mai il fleet pre-processato, così il fallback ricalcola sempre
      localStorage.setItem('mf_cloud_cache', JSON.stringify({
        raw: dati, timestamp: new Date().toISOString()
      }));
      // Pulisci eventuali chiavi legacy che potrebbero contenere fleet vecchi
      localStorage.removeItem('myfleet_data');
      localStorage.removeItem('mf_fleet_cache');
      if (statusDiv) { statusDiv.innerHTML = '✅ Cloud OK — ' + FLEET.length + ' veicoli'; statusDiv.style.color = '#34d399'; }
      console.log('[V42] Cloud sync OK:', FLEET.length, 'veicoli');
      _v37_updateDbStatus();
      return true;
    } else { throw new Error('Nessun dato cloud'); }
  } catch(e) {
    console.warn('[V42] Cloud non disponibile:', e.message);
    var msg = e.message && e.message.indexOf('403') >= 0
      ? '⚠️ Foglio privato — rendi pubblico il Google Sheet'
      : '⚠️ Cloud non disp. — uso dati embedded';
    if (statusDiv) { statusDiv.innerHTML = msg; statusDiv.style.color = '#f97316'; }
    return _caricaDaCacheLocale();
  }
}

function _caricaDaCacheLocale() {
  // Prima prova la cache localStorage (dati cloud recenti)
  var cacheStr = localStorage.getItem('mf_cloud_cache');
  if (cacheStr) {
    try {
      var c = JSON.parse(cacheStr);
      if (c.raw && c.raw.VEICOLI && c.raw.VEICOLI.length > 0) {
        applicaDatiFlotta(c.raw);
        console.log('[V42] Cache locale ripristinata:', FLEET.length, 'veicoli, ts:', c.timestamp);
        return true;
      }
    } catch(e) { console.error('[V42] Errore cache:', e); }
  }
  // Fallback garantito: EMBEDDED_3NF sempre presente nel file
  if (typeof EMBEDDED_3NF !== 'undefined' && EMBEDDED_3NF.VEICOLI && EMBEDDED_3NF.VEICOLI.length > 0) {
    applicaDatiFlotta(EMBEDDED_3NF);
    console.log('[V42] Fallback EMBEDDED_3NF:', FLEET.length, 'veicoli');
    return true;
  }
  return false;
}

// ── Reset periodico 24h ───────────────────────────────────────────────
async function resetPeriodico() {
  var lastReset = localStorage.getItem('mf_last_auto_reset');
  if (lastReset && (new Date() - new Date(lastReset)) < 24 * 3600 * 1000) return;
  console.log('[V42] Reset 24h — risync forzata');
  localStorage.setItem('mf_last_auto_reset', new Date().toISOString());
  localStorage.removeItem('mf_cloud_cache');
  await caricaDatiDaCloud();
  if (currentUser) { renderList(); drawDonut(); }
}

// ── applicaDatiFlotta: normalizza raw 4NF → FLEET / CID_LIST / EP_LIST ─
function applicaDatiFlotta(datiCloud) {
  FLEET = []; cancelledFleet = []; CID_LIST = []; EP_LIST = []; runtime = {};

  var veicoli     = datiCloud.VEICOLI             || datiCloud.veicoli           || [];
  var persone     = datiCloud.PERSONE             || datiCloud.persone           || [];
  var assegnazioni= datiCloud.ASSEGNAZIONI        || datiCloud.assegnazioni      || [];
  var utilizzi    = datiCloud.UTILIZZI            || datiCloud.utilizzi          || [];
  var ztlList     = datiCloud.ZTL                 || datiCloud.ztl               || [];
  var noteOp      = datiCloud.NOTE_OPERATIVE      || datiCloud.noteOperative     || [];
  var easypark    = datiCloud.EASYPARK            || datiCloud.easypark          || [];
  var targheCancellate = datiCloud.TARGHE_CANCELLATE || datiCloud.targheCancellate || [];

  // Dizionari veloci O(1)
  var persMap = {};
  persone.forEach(function(p) {
    var cid = (p.CID || '').toString().trim();
    if (cid) persMap[cid] = p;
  });

  var assDiz = {};
  assegnazioni.forEach(function(a) {
    if (a.ATTIVA === 'SI' && a.TARGA && !assDiz[a.TARGA]) assDiz[a.TARGA] = a;
  });

  var usoDiz = {};
  utilizzi.forEach(function(u) {
    if (u.ATTIVO === 'SI' && u.TARGA && !usoDiz[u.TARGA]) usoDiz[u.TARGA] = u;
  });

  var ztlDiz = {};
  ztlList.forEach(function(z) {
    if (!z.TARGA) return;
    if (!ztlDiz[z.TARGA]) ztlDiz[z.TARGA] = [];
    var c1 = (z['CITTA 1'] || z.CITTA || '').trim();
    var s1 = (z['SCADENZA 1'] || z.SCADENZA || '').trim();
    if (c1) ztlDiz[z.TARGA].push({ citta: c1, scadenza: s1 });
    var c2 = (z['CITTA 2'] || '').trim(), s2 = (z['SCADENZA 2'] || '').trim();
    if (c2) ztlDiz[z.TARGA].push({ citta: c2, scadenza: s2 });
    var c3 = (z['CITTA 3'] || '').trim(), s3 = (z['SCADENZA 3'] || '').trim();
    if (c3) ztlDiz[z.TARGA].push({ citta: c3, scadenza: s3 });
  });

  var noteDiz = {};
  noteOp.forEach(function(n) { if (n.TARGA && n.TESTO) noteDiz[n.TARGA] = n.TESTO; });

  var epSet = {};
  easypark.forEach(function(e) { if (e.ATTIVO === 'SI' && e.TARGA) epSet[e.TARGA] = true; });

  veicoli.forEach(function(v) {
    var targa = (v.TARGA || '').trim().toUpperCase();
    if (!targa || targa === 'NAN') return;

    var ass = assDiz[targa] || null;
    var uso = usoDiz[targa] || null;

    var assoCid = ass ? (ass.CID || '').toString().trim() : '';
    var usoCid  = uso ? (uso.CID || '').toString().trim() : '';
    var assegnatario = assoCid ? (persMap[assoCid] || null) : null;
    var utilizzatore = usoCid  ? (persMap[usoCid]  || null) : null;

    var statoVeicolo = (v.STATO || '').trim();
    var stato = 'Marciante', pool = '', statoAuto = '';

    if (statoVeicolo === 'Officina') {
      stato = 'Officina'; statoAuto = 'Officina';
      pool = ass ? 'Assegnata' : '';
    } else if (statoVeicolo === 'In arrivo') {
      stato = 'In arrivo'; statoAuto = 'In arrivo';
    } else if (uso) {
      var tipoUso = (uso.TIPO_UTILIZZO || '').toUpperCase();
      if (v.VEICOLO_SPECIALE === 'SI' || tipoUso === 'SPECIALI') pool = 'Speciali';
      else if (tipoUso === 'TECNICO') pool = 'Tecnico';
      else if (tipoUso === 'SCORTA') pool = 'Scorta';
      else pool = tipoUso || 'Scorta';
      statoAuto = usoCid ? 'Utilizzatore' : pool;
    } else if (ass) {
      pool = 'Assegnata'; statoAuto = 'Assegnata';
    } else {
      pool = ''; statoAuto = 'Marciante';
    }

    // Persona da mostrare
    var cognomeDisplay = '', nomeDisplay = '', cidDisplay = '';
    if (statoAuto === 'Assegnata' || statoAuto === 'Officina') {
      if (assegnatario) { cognomeDisplay = assegnatario.COGNOME || ''; nomeDisplay = assegnatario.NOME || ''; cidDisplay = assoCid; }
    } else if (statoAuto === 'Utilizzatore') {
      if (utilizzatore) { cognomeDisplay = utilizzatore.COGNOME || ''; nomeDisplay = utilizzatore.NOME || ''; cidDisplay = usoCid; }
      else if (assegnatario) { cognomeDisplay = assegnatario.COGNOME || ''; nomeDisplay = assegnatario.NOME || ''; cidDisplay = assoCid; }
    }

    var pinEni = v.PIN_ENILIVE ? String(v.PIN_ENILIVE).trim().replace('.0','') : null;
    var pinQ8  = v.PIN_Q8      ? String(v.PIN_Q8).trim().replace('.0','')      : null;

    FLEET.push({
      targa: targa, tipo: (v.TIPO_VEICOLO || '').trim(),
      sede: (v.SEDE || '').trim(),
      cognome: cognomeDisplay, nome: nomeDisplay, cid: cidDisplay,
      stato: stato, statoAuto: statoAuto, pool: pool,
      carburante: '', note: noteDiz[targa] || null,
      officina: null, data_officina: '', fine_noleggio: '', inizio_noleggio: '', scad_revisione: '',
      aot: null, cle: (v.VIA_PALERMO || null),
      pin_eni: pinEni, pin_q8: pinQ8,
      ztl: ztlDiz[targa] || [], richieste: [],
      _assegnatario_cognome: assegnatario ? (assegnatario.COGNOME || '') : '',
      _assegnatario_nome:    assegnatario ? (assegnatario.NOME    || '') : '',
      _assegnatario_cid: assoCid,
      _utilizzatore_cognome: utilizzatore ? (utilizzatore.COGNOME || '') : '',
      _utilizzatore_nome:    utilizzatore ? (utilizzatore.NOME    || '') : '',
      _utilizzatore_cid: usoCid,
      _easypark: epSet[targa] ? true : false
    });
  });

  CID_LIST = persone.map(function(p) {
    return { cid: (p.CID || '').toString().trim(), cognome: p.COGNOME || '', nome: p.NOME || '', mail: p.EMAIL || null, ruolo: 'Assegnatario' };
  }).filter(function(c){ return c.cid; });

  EP_LIST = easypark.filter(function(e){ return e.ATTIVO === 'SI' && e.TARGA; }).map(function(e) {
    return { targa: e.TARGA, nome: '', cognome: '', telefono: '', email: '' };
  });

  cancelledFleet = targheCancellate.map(function(c) {
    var t = (c.TARGA || '').trim().toUpperCase();
    return { targa: t, tipo: c.TIPO_VEICOLO || '', note: c.NOTE || null, deletedAt: c.DATA_CANCELLAZIONE || '' };
  }).filter(function(c){ return c.targa && c.targa !== 'NAN'; });

  saveFleet();
  console.log('[V42] applicaDatiFlotta: ' + FLEET.length + ' veicoli, ' + CID_LIST.length + ' CID');
}

