var _emAcTimeout = null;

function emOnCognomeInput() {
  clearTimeout(_emAcTimeout);
  _emAcTimeout = setTimeout(function() {
    var q = document.getElementById('em-cognome').value.trim().toLowerCase();
    var ac = document.getElementById('em-cognome-ac');
    if (q.length < 2) { ac.style.display = 'none'; return; }
    var matches = [], seen = {};
    for (var i = 0; i < CID_LIST.length; i++) {
      var c = CID_LIST[i];
      if (!c.cognome) continue;
      var key = c.cid;
      if (seen[key]) continue;
      if (c.cognome.toLowerCase().indexOf(q) !== -1) {
        seen[key] = 1;
        matches.push({cid: c.cid, cognome: c.cognome, nome: c.nome, targa:''});
      }
      if (matches.length >= 8) break;
    }
    if (matches.length < 6) {
      for (var i = 0; i < FLEET.length; i++) {
        var v = FLEET[i];
        if (!v.cognome) continue;
        var key = v.cid || (v.cognome + v.nome);
        if (seen[key]) continue;
        if (v.cognome.toLowerCase().indexOf(q) !== -1) {
          seen[key] = 1;
          matches.push({cid: v.cid||'', cognome: v.cognome, nome: v.nome||'', targa: v.targa});
        }
        if (matches.length >= 8) break;
      }
    }
    if (!matches.length) { ac.style.display = 'none'; return; }
    ac.innerHTML = matches.map(function(v) {
      return '<div class="autocomplete-item" onclick="emFillFromCidObj(' + JSON.stringify({targa:v.targa||'',cognome:v.cognome||'',nome:v.nome||'',cid:v.cid||''}).replace(/"/g, '&quot;') + ')">' +
        '<span>' + escapeHtml(v.cognome) + ' ' + escapeHtml(v.nome || '') + '</span>' +
        (v.cid ? '<span style="color:var(--acc);font-family:monospace;font-size:11px;margin-left:6px">' + escapeHtml(v.cid) + '</span>' : '') +
        '</div>';
    }).join('');
    ac.style.display = 'block';
  }, 200);
}

