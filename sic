function _drawDonutCore(){
  // Usa curFilter globale che è sempre aggiornato
  var f = (typeof curFilter !== 'undefined') ? curFilter : 'all';

  var segs = [];

  if (f === 'Scorta' || f === 'Tecnico' || f === 'Speciali') {
    var liberi = 0, inUso = 0;
    for (var i = 0; i < FLEET.length; i++) {
      var v = FLEET[i];
      if (v.pool !== f) continue;
      if (isLibero(v)) liberi++; else inUso++;
    }
    var tot = FLEET.filter(function(v){ return v.pool === f; }).length;
    segs = [
      {v: liberi, c: '#22c55e', l: f + ' liberi'},
      {v: inUso,  c: '#f97316', l: f + ' in uso'}
    ];
    _renderDonut(segs, f, tot + '');
    return;
  }

  if (f === 'Assegnata') {
    var assMarc = 0, assOff = 0, assArr = 0;
    for (var i = 0; i < FLEET.length; i++) {
      var v = FLEET[i];
      if (v.pool !== 'Assegnata') continue;
      var st = getStato(v);
      if (st === 'Officina') assOff++;
      else if (st === 'In arrivo') assArr++;
      else assMarc++;
    }
    var tot = FLEET.filter(function(v){ return v.pool === 'Assegnata'; }).length;
    segs = [
      {v: assMarc, c: '#22c55e', l: 'Marcianti'},
      {v: assOff,  c: '#f97316', l: 'In officina'},
      {v: assArr,  c: '#3b82f6', l: 'In arrivo'}
    ];
    _renderDonut(segs, 'Assegnate', tot + '');
    return;
  }

  // Default (all / m / o / arrivo): vista completa flotta
  var nAss = 0, nScortaLib = 0, nScortaUso = 0, nTecLib = 0, nTecUso = 0, nSpecLib = 0, nSpecUso = 0, nOff = 0, nArr = 0;
  for (var i = 0; i < FLEET.length; i++) {
    var v = FLEET[i];
    var st = getStato(v);
    if (st === 'Officina') { nOff++; continue; }
    if (st === 'In arrivo') { nArr++; continue; }
    var p = v.pool || '';
    if (p === 'Assegnata')     nAss++;
    else if (p === 'Scorta')   { if (isLibero(v)) nScortaLib++; else nScortaUso++; }
    else if (p === 'Tecnico')  { if (isLibero(v)) nTecLib++;    else nTecUso++;    }
    else if (p === 'Speciali') { if (isLibero(v)) nSpecLib++;   else nSpecUso++;   }
  }
  segs = [
    {v: nAss,       c: '#22c55e', l: 'Assegnate'},
    {v: nScortaLib, c: '#38bdf8', l: 'Scorta libere'},
    {v: nScortaUso, c: '#f97316', l: 'Scorta in uso'},
    {v: nTecLib,    c: '#a78bfa', l: 'Tecnico liberi'},
    {v: nTecUso,    c: '#7c3aed', l: 'Tecnico in uso'},
    {v: nSpecLib,   c: '#f472b6', l: 'Speciali liberi'},
    {v: nSpecUso,   c: '#be185d', l: 'Speciali in uso'},
    {v: nOff,       c: '#ef4444', l: 'In officina'},
    {v: nArr,       c: '#3b82f6', l: 'In arrivo'}
  ];
  _renderDonut(segs, 'Flotta', FLEET.length + '');
}

function _renderDonut(segs, centerLabel1, centerLabel2) {
  var canvas = document.getElementById('donutCanvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d'), cx = 70, cy = 70, R = 58, ri = 36;
  ctx.clearRect(0, 0, 140, 140);
  var tot = 0;
  segs.forEach(function(s){ tot += s.v; });
  if (!tot) tot = 1;
  var ang = -Math.PI / 2;
  segs.forEach(function(seg) {
    if (!seg.v) return;
    var sw = (seg.v / tot) * 2 * Math.PI;
    ctx.beginPath(); ctx.moveTo(cx, cy);
    ctx.arc(cx, cy, R, ang, ang + sw); ctx.closePath();
    ctx.fillStyle = seg.c; ctx.fill();
    // Label numero nel slice (solo se abbastanza grande)
    if (sw > 0.35) {
      var mid = ang + sw / 2;
      var lx = cx + Math.cos(mid) * (R + ri) / 2;
      var ly = cy + Math.sin(mid) * (R + ri) / 2;
      ctx.fillStyle = '#fff';
      ctx.font = 'bold 10px Barlow,sans-serif';
      ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
      ctx.fillText(seg.v, lx, ly);
    }
    ang += sw;
  });
  // Foro centrale
  ctx.beginPath(); ctx.arc(cx, cy, ri, 0, 2 * Math.PI);
  ctx.fillStyle = '#0e0e0e'; ctx.fill();
  ctx.fillStyle = '#e8f0f8';
  ctx.font = 'bold 9px Barlow,sans-serif';
  ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
  ctx.fillText(centerLabel1, cx, cy - 6);
  ctx.fillText(centerLabel2, cx, cy + 6);
  // Legenda
  var leg = document.getElementById('donutLegend');
  if (leg) leg.innerHTML = segs.filter(function(s){ return s.v > 0; }).map(function(s) {
    return '<div class="leg-row"><div class="leg-dot" style="background:' + s.c + '"></div>' +
      '<span class="leg-lbl">' + s.l + '</span><span class="leg-n">' + s.v + '</span></div>';
  }).join('');
}

