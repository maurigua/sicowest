function generaDen() {
  var btn = document.getElementById('denSubmitBtn');
  btn.disabled = true;
  btn.textContent = 'Caricamento PDF...';
  fetch('DEN001_app.pdf')
    .then(function(resp) {
      if (!resp.ok) throw new Error('PDF template non trovato. Assicurati che DEN001_app.pdf sia nella stessa cartella.');
      return resp.arrayBuffer();
    })
    .then(function(buf) {
      btn.textContent = 'Compilazione...';
      var bytes = new Uint8Array(buf);
      var b64 = '';
      var chunk = 8192;
      for (var i = 0; i < bytes.length; i += chunk) {
        b64 += String.fromCharCode.apply(null, bytes.subarray(i, i + chunk));
      }
      var pdfBase64 = btoa(b64);
      var pdfBytes = Uint8Array.from(atob(pdfBase64), function(c) { return c.charCodeAt(0); });
      return PDFLib.PDFDocument.load(pdfBytes);
    })
    .then(function(pdfDoc) {
      var form = pdfDoc.getForm();
      function fillField(name, value) {
        try { form.getTextField(name).setText(value || ''); } catch(e) {}
      }
      var dg = document.getElementById('denGiorno').value;
      var dm = document.getElementById('denMese').value;
      var da = document.getElementById('denAnno').value;
      fillField('Giorno', dg);
      fillField('Mese', dm);
      fillField('Anno', da);
      fillField('Ora', document.getElementById('denOra').value);
      fillField('Luogo', document.getElementById('denLuogo').value);
      fillField('Targa', document.getElementById('denTarga').value);
      fillField('Marca e Tipo', document.getElementById('denMarca').value);
      fillField('KM', document.getElementById('denKm').value);
      fillField('Compagnia Assicuratrice', 'Leasys SpA');
      fillField('Locatario', 'FiberCop S.p.A.');
      fillField('Conducente', document.getElementById('denConducente').value);
      fillField('Indirizzo', document.getElementById('denIndirizzo').value);
      fillField('Telefono', document.getElementById('denTelefono').value);
      fillField('NOTE', document.getElementById('denNote').value);
      fillField('Data Denuncia', dg + '/' + dm + '/' + da);
      if (denMode === 'incidente') {
        fillField('Targa - B', document.getElementById('denTargaB').value);
        fillField('Marca e Tipo - B', document.getElementById('denMarcaB').value);
        fillField('Cognome - B', document.getElementById('denCognomeB').value);
        fillField('Nome - B', document.getElementById('denNomeB').value);
        fillField('Indirizzo e Telefono - B', document.getElementById('denIndirizzoB').value);
        fillField('Compagnia Assicuratrice - B', document.getElementById('denCompagniaB').value);
        fillField('Numero Polizza - B', document.getElementById('denPolizzaB').value);
        fillField('Indirizzo - B', document.getElementById('denIndirizzoCompB').value);
      }
      return pdfDoc.save();
    })
    .then(function(pdfOut) {
      var blob = new Blob([pdfOut], { type: 'application/pdf' });
      var url = URL.createObjectURL(blob);
      var a = document.createElement('a');
      a.href = url;
      var targa = document.getElementById('denTarga').value;
      var dg = document.getElementById('denGiorno').value;
      var dm = document.getElementById('denMese').value;
      var da = document.getElementById('denAnno').value;
      a.download = 'DEN_' + targa + '_' + dg + dm + da + '.pdf';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
      btn.disabled = false;
      btn.textContent = '📋 Genera PDF';
      closeAll();
      showToast('✅ DEN generato e scaricato');
    })
    .catch(function(e) {
      btn.disabled = false;
      btn.textContent = '📋 Genera PDF';
      showToast('❌ ' + e.message, true);
    });
}

function rilevaPosizione(callback, onError) {
  if (!navigator.geolocation) { if (onError) onError('GPS non supportato'); return; }
  navigator.geolocation.getCurrentPosition(function(pos) {
    var lat = pos.coords.latitude.toFixed(6), lng = pos.coords.longitude.toFixed(6);
    fetch('https://nominatim.openstreetmap.org/reverse?lat=' + lat + '&lon=' + lng + '&format=json&accept-language=it')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        gpsCoords = { lat: lat, lng: lng, address: data.display_name || ('Lat:' + lat + ',Lng:' + lng) };
        if (callback) callback(gpsCoords);
      }).catch(function() {
        gpsCoords = { lat: lat, lng: lng, address: 'Lat:' + lat + ', Lng:' + lng };
        if (callback) callback(gpsCoords);
      });
  }, function(err) {
    var msg = 'Errore GPS';
    if (err.code === 1) msg = 'Permesso GPS negato';
    else if (err.code === 2) msg = 'Posizione non disponibile';
    else if (err.code === 3) msg = 'Timeout GPS';
    if (onError) onError(msg); else showToast(msg, true);
  }, { enableHighAccuracy: true, timeout: 10000, maximumAge: 30000 });
}
