function closeEditModal() {
  document.getElementById('editModalOverlay').classList.remove('open');
  editTarga = null;
}

function saveEditModal() {
  var v = findVehicle(editTarga);
  if (!v) return;
  var newCognome = document.getElementById('em-cognome').value.trim();
  var newNome = document.getElementById('em-nome').value.trim();
  var newCid = document.getElementById('em-cid').value.trim();
  if (newCid && newCid !== v.cid) {
    var cidEntry = findCid(newCid);
    if (cidEntry) {
      newCognome = cidEntry.cognome;
      newNome = cidEntry.nome;
    }
  }
  v.cognome = newCognome;
  v.nome = newNome;
  v.cid = newCid || '';
  v.tipo = document.getElementById('em-tipo').value.trim() || v.tipo;
  v.sede = document.getElementById('em-sede').value.trim() || v.sede;
  v.carburante = document.getElementById('em-carb').value || v.carburante;
  var newStato = document.getElementById('em-stato').value;
  v.stato = newStato;
  v.pool = document.getElementById('em-pool').value || '';
  // Aggiorna statoAuto per riflettere il principio fondamentale:
  // - Persona + pool → Utilizzatore (uso attivo dichiarato)
  // - Persona + no pool → Assegnata
  // - No persona + pool → pool puro (es. 'Tecnico', 'Scorta', 'Speciali')
  // - Officina / In arrivo → mantiene statoAuto corrispondente
  if (newStato === 'Officina') {
    v.statoAuto = 'Officina';
  } else if (newStato === 'In arrivo') {
    v.statoAuto = 'In arrivo';
  } else {
    var hasPerson = (v.cognome || '').trim() || (v.nome || '').trim() || (v.cid || '').trim();
    var truePools = ['Scorta','Tecnico','Speciali'];
    if (hasPerson && truePools.indexOf(v.pool) !== -1) {
      v.statoAuto = 'Utilizzatore';
    } else if (hasPerson) {
      v.statoAuto = 'Assegnata';
    } else if (v.pool && truePools.indexOf(v.pool) !== -1) {
      v.statoAuto = v.pool; // pool puro: Scorta, Tecnico, Speciali
    } else {
      v.statoAuto = 'Assegnata';
    }
  }
  v.officina = document.getElementById('em-officina').value.trim() || null;
  v.data_officina = document.getElementById('em-data-officina').value || null;
  v.fine_noleggio = document.getElementById('em-fine-noleggio').value || null;
  v.inizio_noleggio = document.getElementById('em-inizio-noleggio').value || null;
  v.aot = document.getElementById('em-aot').value.trim() || null;
  v.cle = document.getElementById('em-cle').value.trim() || null;
  v.scad_revisione = document.getElementById('em-scad-revisione').value || null;
  v.pin_eni = document.getElementById('em-pin-eni').value.trim() || null;
  v.pin_q8 = document.getElementById('em-pin-q8').value.trim() || null;
  v.note = document.getElementById('em-note').value.trim() || null;
  v.ztl = getZtlFromRows();
  if (v.stato === 'Officina') {
    if (!runtime[v.targa]) runtime[v.targa] = {};
    runtime[v.targa].stato = 'Officina';
    saveOLS(v.targa);
  } else if (v.stato !== 'Officina' && runtime[v.targa] && runtime[v.targa].stato === 'Officina') {
    runtime[v.targa].stato = null;
    removeOLS(v.targa);
  }
  // [V43] Bloom Audit: costruisce payload con entity_id per futura API Bloomoove
  var _bloomPayload = {
    entity_id: ENTITY_ID,
    targa: v.targa,
    stato: v.stato,
    assegnatario: (v.cognome||'') + ' ' + (v.nome||''),
    sede: v.sede || '',
    timestamp: Date.now()
  };
  console.log('[V43 Bloomoove] Entity-locked save payload:', _bloomPayload);
  saveFleet();
  closeEditModal();
  showToast('Salvato');
}

function cancellaVeicolo() {
  var v = findVehicle(editTarga);
  if (!v) return;
  if (!confirm('Cancellare ' + v.targa + ' dalla flotta? Verrà spostato nelle cancellate.')) return;
  FLEET = FLEET.filter(function(x) { return x.targa !== v.targa; });
  var already = cancelledFleet.some(function(c) { return c.targa === v.targa; });
  if (!already) cancelledFleet.push({ targa: v.targa, tipo: v.tipo || '', cid: v.cid || '', note: v.note || null, deletedAt: new Date().toISOString().slice(0,10) });
  delete runtime[v.targa];
  removeOLS(v.targa);
  saveFleet();
  closeEditModal();
  showToast(v.targa + ' cancellato dalla flotta');
}

