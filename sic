      return el && el.style.display !== 'none' && el.style.display !== '';
    });
    if (!anyVisible) {
      console.warn('[V42] Safety timeout: forzo homeScreen');
      var hs2 = document.getElementById('homeScreen');
      if (hs2) hs2.style.display = 'flex';
    }
  }, 10000);

  // STEP 2: carica cache locale sincrona (nessun await — istantaneo)
  var hasCacheData = _caricaDaCacheLocale();

  // STEP 3: se c'è sessione salvata E abbiamo dati (cache), avvia l'app subito
  var savedSession = loadSession();
  var appStarted = false;
  if (savedSession && savedSession.cid && hasCacheData && FLEET.length > 0) {
    currentUser = savedSession;
    if (currentUser.isAdmin) { userSede = 'ADMIN'; }
    else {
      var myCid = (currentUser.cid || '').toString().trim();
      var vSede = FLEET.find(function(f){ return cidMatches(f.cid, myCid) || cidMatches(f._assegnatario_cid, myCid); });
      userSede = vSede ? vSede.sede : null;
    }
    clearTimeout(safetyTimer);
    if (hs) hs.style.display = 'none';
    startApp();
    appStarted = true;
  }

  // STEP 4: sync cloud in background (non blocca l'UI)
  _syncCloudInBackground(appStarted).then(function() {
    clearTimeout(safetyTimer);
  }).catch(function() {
    clearTimeout(safetyTimer);
  });
});

async function _syncCloudInBackground(appAlreadyStarted) {
  // [V43 MANTENUTO] Legal Entity Lock: ENTITY_ID viene incluso nei payload cloud
  var statusDiv = document.getElementById('homeDbStatus');
  try {
    // Reset periodico 24h: se passate 24h dalla last sync, forza refresh
    var lastReset = localStorage.getItem('mf_last_auto_reset');
    if (lastReset && (new Date() - new Date(lastReset)) < 24 * 3600 * 1000 && appAlreadyStarted) {
      // Meno di 24h e app già avviata con cache: non bloccare, sync silenzioso
      if (statusDiv) statusDiv.innerHTML = '✅ DB da cache — ' + FLEET.length + ' veicoli';
      // Sync silenzioso asincrono
      setTimeout(async function() {
        try {
          var dati = await fetchGoogleSheetCompleto();
          if (dati && dati.VEICOLI && dati.VEICOLI.length > 0) {
            applicaDatiFlotta(dati);
            localStorage.setItem('mf_cloud_cache', JSON.stringify({ raw: dati, timestamp: new Date().toISOString() }));
            localStorage.setItem('mf_last_sync_success', new Date().toISOString());
            console.log('[V42] Sync silenziosa OK:', FLEET.length, 'veicoli');
            if (listVisible) { renderList(); drawDonut(); }
            _v37_updateDbStatus();
          }
        } catch(e) { console.warn('[V42] Sync silenziosa fallita:', e.message); }
      }, 2000); // aspetta 2s che l'app sia avviata prima di syncare
      return;
    }

    // Prima sync o >24h: forza aggiornamento
    var ok = await caricaDatiDaCloud();
    if (ok) {
      localStorage.setItem('mf_last_auto_reset', new Date().toISOString());
      if (!appAlreadyStarted) {
        // Primo avvio senza cache: ora abbiamo i dati, controlla sessione
        var savedSession = loadSession();
        var hs = document.getElementById('homeScreen');
        if (savedSession && savedSession.cid) {
          currentUser = savedSession;
          if (currentUser.isAdmin) { userSede = 'ADMIN'; }
          else {
            var myCid = (currentUser.cid || '').toString().trim();
            var vSede = FLEET.find(function(f){ return cidMatches(f.cid, myCid) || cidMatches(f._assegnatario_cid, myCid); });
            userSede = vSede ? vSede.sede : null;
          }
          if (hs) hs.style.display = 'none';
          startApp();
        } else {
          if (hs) hs.style.display = 'flex';
          _v37_updateDbStatus();
        }
      } else {
        // App già avviata: aggiorna silenziosamente
        if (listVisible) { renderList(); drawDonut(); }
        _v37_updateDbStatus();
      }
    } else if (!appAlreadyStarted) {
      // Nessun cloud, nessuna cache: mostra homeScreen con messaggio
      var hs = document.getElementById('homeScreen');
      if (hs) hs.style.display = 'flex';
      if (statusDiv) { statusDiv.innerHTML = '⚠️ Nessun dato. Connettiti e premi "Aggiorna DB da Cloud"'; statusDiv.style.color = '#f97316'; }
    }
  } catch(e) {
    console.error('[V42] _syncCloudInBackground errore:', e);
    if (!appAlreadyStarted) {
      var hs = document.getElementById('homeScreen');
      if (hs) hs.style.display = 'flex';
    }
  }
}

