      var ztlC = v.ztl && v.ztl[0] ? v.ztl[0].citta : '';
      var ztlF = v.ztl && v.ztl[0] ? v.ztl[0].scadenza : '';
      dbRows.push([
        v.targa||'', v.cognome||'', v.nome||'', v.cid||'',
