function renderScortaInto(containerId, selectFn) {
  var sedeCorrente = (curVehicle && curVehicle.sede) ? curVehicle.sede.trim() : '';
  var sc = sedeCorrente ? getScortaPerCitta(sedeCorrente) : [];
  var html = '';

  if (sc.length) {
    // Scorta locale disponibile
    for (var i = 0; i < sc.length; i++) {
      html += '<div class="scorta-card" onclick="' + selectFn + '(\'' + sc[i].targa + '\',this)">' +
        '<div class="scorta-top"><span class="targa">' + sc[i].targa + '</span>' +
        (sc[i].sede ? '<span style="font-size:11px;color:var(--muted);margin-left:8px">📍 ' + escapeHtml(sc[i].sede) + '</span>' : '') +
        '</div><div class="vtipo">' + escapeHtml(sc[i].tipo || '') + '</div></div>';
    }
  } else {
    // Nessuna scorta nella sede corrente → mostra alternative
    var altSedi = _getAlternativeScortaCitta(sedeCorrente);
    html = '<div class="no-scorta" style="margin-bottom:12px">🚗 Nessuna Scorta libera a <strong>' + escapeHtml(sedeCorrente || 'N/D') + '</strong></div>';

    if (altSedi.length) {
      // Suggerisci le città più vicine con scorta disponibile
      html += '<div style="font-size:12px;color:var(--muted);margin-bottom:8px;font-weight:600">📍 Scorta disponibile in:</div>';
      altSedi.forEach(function(item) {
        html += '<div class="scorta-card" onclick="_espandiScortaCitta(\'' + escapeHtml(item.sede) + '\',\'' + containerId + '\',\'' + selectFn + '\')" style="border:1px dashed rgba(56,189,248,.4);cursor:pointer">' +
          '<div class="scorta-top"><span style="font-weight:700;color:var(--acc)">📍 ' + escapeHtml(item.sede) + '</span>' +
          '<span style="font-size:12px;color:var(--muted);margin-left:auto">' + item.count + ' mezzi liberi</span></div>' +
          '<div class="vtipo">Tocca per vedere i veicoli disponibili</div></div>';
      });
    } else {
      html += '<div style="font-size:12px;color:var(--muted);margin-bottom:8px">Nessuna Scorta disponibile in tutto il territorio.</div>';
    }

    // Input libero per cercare in qualsiasi città
    html += '<div style="margin-top:12px"><label class="fl">🔍 Cerca in un\'altra città</label>' +
      '<div style="display:flex;gap:8px">' +
      '<input class="fi" id="scortaCittaInput_' + containerId + '" placeholder="es. Agrigento, Trapani..." style="flex:1" list="scortaCittaList_' + containerId + '">' +
      '<datalist id="scortaCittaList_' + containerId + '">' +
      _getAllScortaCitta().map(function(s){ return '<option value="' + escapeHtml(s) + '">'; }).join('') +
      '</datalist>' +
      '<button class="bsub bsub-blue" style="flex:0;padding:10px 16px;font-size:14px" ' +
      'onclick="_cercaScortaInCitta(document.getElementById(\'scortaCittaInput_' + containerId + '\').value,\'' + containerId + '\',\'' + selectFn + '\')">Cerca</button>' +
      '</div></div>';

    html += '<div id="scortaAltList_' + containerId + '"></div>';
  }

  document.getElementById(containerId).innerHTML = html;
}

// Restituisce città con scorta libera ordinate per numero di mezzi disponibili
function _getAlternativeScortaCitta(escludiSede) {
  var map = {};
  FLEET.forEach(function(v) {
    if (v.pool !== 'Scorta' || getStato(v) !== 'Marciante' || !isLibero(v)) return;
    if (!v.sede || normSede(v.sede) === normSede(escludiSede)) return;
    var s = v.sede.trim();
    map[s] = (map[s] || 0) + 1;
  });
  return Object.keys(map).sort(function(a,b){ return map[b]-map[a]; }).slice(0,5).map(function(s){ return {sede:s, count:map[s]}; });
}

// Tutte le città con almeno una scorta libera (per datalist)
function _getAllScortaCitta() {
  var set = {};
  FLEET.forEach(function(v) {
    if (v.pool !== 'Scorta' || getStato(v) !== 'Marciante' || !isLibero(v) || !v.sede) return;
    set[v.sede.trim()] = true;
  });
  return Object.keys(set).sort();
}

// Mostra i veicoli scorta di una città specifica nell'elenco alternativo
function _espandiScortaCitta(sede, containerId, selectFn) {
  var sc = getScortaPerCitta(sede);
  var html = '<div style="font-size:11px;color:var(--muted);font-weight:700;margin:8px 0 6px">Scorta a ' + escapeHtml(sede) + ':</div>';
