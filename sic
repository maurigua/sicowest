function getFiltered() {
  var q = curSearch.toLowerCase(), filtered = [];
  for (var i = 0; i < FLEET.length; i++) {
    var v = FLEET[i], stato = getStato(v);
    if (curFilter === 'all') {
      if (stato === 'Ritirata' || stato === 'Ceduta') continue;
      if (stato === 'In arrivo' && curFilter === 'all' && (!currentUser || (!currentUser.isAdmin && !(currentUser.ruolo === 'Gestore Op.' && currentUser.gestoreOpFlottaOn)))) continue;
    } else if (curFilter === 'm') { if (stato !== 'Marciante') continue; }
    else if (curFilter === 'o') { if (stato !== 'Officina') continue; }
    else if (curFilter === 'arrivo') { if (stato !== 'In arrivo') continue; }
    else if (curFilter === 'cancellate') { continue;  }
    else { if (v.pool !== curFilter) continue; if (stato === 'Ritirata' || stato === 'Ceduta') continue; }
    if (q) {
      var hay = (v.targa + ' ' + (v.cognome || '') + ' ' + (v.nome || '') + ' ' + (v.sede || '') + ' ' + (v.tipo || '') + ' ' + (v.pool || '') + ' ' + (v.cid || '')).toLowerCase();
      var cidMatch = false;
      if (/^\d+$/.test(q.trim())) {
        if (v.cid && cidMatches(v.cid, q.trim())) cidMatch = true;
        var rt = runtime[v.targa];
        if (rt && rt.assegnato_a && !rt.rilasciato && typeof rt.assegnato_a === 'object' && rt.assegnato_a.cid) {
          if (cidMatches(rt.assegnato_a.cid, q.trim())) cidMatch = true;
        }
      }
      if (!cidMatch && hay.indexOf(q) === -1) continue;
    }
    filtered.push(v);
  }
  return filtered;
}

// [MANTENUTO V42] Filtro visibilità: Admin vede tutto, altri solo propria sede
function getFilteredForUser(all) {
  // 1. Admin: vede tutto
  if (!currentUser || currentUser.isAdmin) return all;

  var ruolo = currentUser.ruolo || 'Assegnatario';
  var myCid = (currentUser.cid || '').toString().trim();
  var pren = getPrenot().map(function(p) { return p.targa; });

  // 2. Gestore Op. switch ON: vede tutta la flotta (gestito in renderList via isAdmin simulato)
  if (ruolo === 'Gestore Op.' && currentUser.gestoreOpFlottaOn) return all;

  // 3. Gestore Op. switch OFF: vede solo la sua auto (come Assegnatario)
  if (ruolo === 'Gestore Op.') {
    return all.filter(function(v) {
      if (runtime[v.targa] && runtime[v.targa].rilasciato === true) return false;
      if (cidMatches(v.cid, myCid)) return true;
      var rt = runtime[v.targa];
      if (rt && rt.assegnato_a && !rt.rilasciato) {
        if (typeof rt.assegnato_a === 'object' && rt.assegnato_a.cid) {
          if (cidMatches(rt.assegnato_a.cid, myCid)) return true;
        }
      }
      if (pren.indexOf(v.targa) !== -1) return true;
      return false;
    });
  }

  // 3. Assegnatario: solo il suo veicolo assegnato (+ pool in carico/prenotato + pool scorta/tecnico se modalità sostituzione attiva)
  if (ruolo === 'Assegnatario' || (ruolo !== 'Gestore Op.' && ruolo !== 'Ospite' && ruolo !== 'Driver Aut.' && !currentUser.isAdmin)) {
    var mySede3 = userSede || localStorage.getItem('mf_user_sede_' + myCid) || '';
    var inModalitaSostituzione = (typeof _richiestaPoolAttiva !== 'undefined' && _richiestaPoolAttiva);
    var filtered = all.filter(function(v) {
      if (runtime[v.targa] && runtime[v.targa].rilasciato === true) return false;
      // Auto assegnata fissa: match CID diretto o via _assegnatario_cid
      if (cidMatches(v.cid, myCid) || cidMatches(v._assegnatario_cid, myCid)) return true;
      // Auto da pool: in carico via runtime
      var rt = runtime[v.targa];
      if (rt && rt.assegnato_a && !rt.rilasciato) {
        if (typeof rt.assegnato_a === 'object' && rt.assegnato_a.cid) {
          if (cidMatches(rt.assegnato_a.cid, myCid)) return true;
        }
      }
      // Auto da pool: prenotata
      if (pren.indexOf(v.targa) !== -1) return true;
      // Pool Scorta/Tecnico liberi: SOLO se in modalità sostituzione e sede nota e corrisponde
      // (NON mostrare Speciali dalla home — hanno pulsante dedicato)
      if ((v.pool === 'Scorta' || v.pool === 'Tecnico') && inModalitaSostituzione &&
          getStato(v) === 'Marciante' && isLibero(v)) {
        if (!mySede3) return false;
        if (normSede(v.sede) === normSede(mySede3)) return true;
      }
      return false;
    });
    // Fallback: CID non trovato in assegnazioni → cerca direttamente per CID in FLEET
    if (filtered.length === 0 && myCid) {
      filtered = FLEET.filter(function(v) {
        var stato = getStato(v);
        if (stato === 'Ritirata' || stato === 'Ceduta') return false;
        return cidMatches(v.cid, myCid) || cidMatches(v._assegnatario_cid, myCid);
      });
    }
    return filtered;
  }

  // 4. Ospite (Guest): SOLO la card del veicolo che ha in carico
  if (ruolo === 'Ospite' || currentUser.isGuest) {
    return all.filter(function(v) {
      if (runtime[v.targa] && runtime[v.targa].rilasciato === true) return false;
      var rt = runtime[v.targa];
      if (rt && rt.assegnato_a && !rt.rilasciato) {
        if (typeof rt.assegnato_a === 'object' && rt.assegnato_a.cid) {
          if (cidMatches(rt.assegnato_a.cid, myCid)) return true;
        }
      }
      if (pren.indexOf(v.targa) !== -1) return true;
      return false;
    });
  }

  // 5. Driver Aut.: lista pool disponibili nella sua sede + auto in carico
  if (ruolo === 'Driver Aut.') {
    var driverSede = userSede || localStorage.getItem('mf_user_sede_' + currentUser.cid);
    return all.filter(function(v) {
      if (runtime[v.targa] && runtime[v.targa].rilasciato === true) return false;
      var rt = runtime[v.targa];
      if (rt && rt.assegnato_a && !rt.rilasciato) {
        if (typeof rt.assegnato_a === 'object' && rt.assegnato_a.cid) {
          if (cidMatches(rt.assegnato_a.cid, myCid)) return true;
        }
      }
      var poolDisponibili = ['Scorta', 'Speciale', 'Tecnico', 'Speciali'];
      if (poolDisponibili.indexOf(v.pool) !== -1 && getStato(v) === 'Marciante') {
        if (driverSede && normSede(v.sede) === normSede(driverSede)) return true;
        if (!driverSede) return true;
      }
      return false;
    });
  }

  // Fallback: ruolo non riconosciuto → lista vuota per sicurezza
  return [];
}

