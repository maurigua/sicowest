function qrCidLogin() {
  var cid = (document.getElementById('qrCidInput').value || '').trim();
  var errEl = document.getElementById('qrCidErr');
  var targa = _v37_pendingTarga;
  errEl.textContent = '';

  if (!cid) { errEl.textContent = 'Inserisci il tuo CID'; return; }
  if (!targa) { errEl.textContent = 'Errore: nessuna targa selezionata'; return; }

  function sameCid(a,b){ return (a||'').replace(/^0+/,'') === (b||'').replace(/^0+/,''); }

  var nome = '', cognome = '';

  if (FLEET && FLEET.length) {
    // DB caricato: verifica assegnatario
    var veicolo = null;
    for (var i=0;i<FLEET.length;i++) { if(FLEET[i].targa===targa){veicolo=FLEET[i];break;} }
    if (!veicolo) { errEl.textContent = '⚠️ Veicolo non trovato nel DB'; return; }
    var cidVeicolo = veicolo.cid || '';
    if (!cidVeicolo) { errEl.textContent = '⚠️ Nessun assegnatario per questo veicolo'; return; }
    if (!sameCid(cid, cidVeicolo)) {
      errEl.textContent = '❌ Non sei l\'assegnatario di questo veicolo';
      return;
    }
    var entry = null;
    for (var j=0;j<CID_LIST.length;j++) { if(sameCid(CID_LIST[j].cid,cid)){entry=CID_LIST[j];break;} }
    nome = entry ? (entry.nome||'') : (veicolo.nome||'');
    cognome = entry ? (entry.cognome||'') : (veicolo.cognome||'');
  } else {
    // DB non caricato: accesso base senza verifica
    nome = ''; cognome = '';
  }

  currentUser = {
    cid: cid,
    nome: nome,
    cognome: cognome,
    isAdmin: false,
    isGuest: false,
    isGestoreOp: false,
    ruolo: 'Assegnatario'
  };

  document.getElementById('qrCidOverlay').style.display = 'none';
  document.getElementById('homeScreen').style.display = 'none';
  _v37_pendingTarga = null;
  saveSession(currentUser);
  postLoginFlow();
}

