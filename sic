    var wb = XLSX.utils.book_new();

    var dbCols = ['Targa','Cognome','Nome','Cid',"Stato dell'auto",'Tipologia pool','Sede',
      'Tipo veicolo','tipo carburante','Promemoria operativo','Officina',
