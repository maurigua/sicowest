// 2. STATO CHAT
var chatOpen = false;

function toggleChat() {
  chatOpen = !chatOpen;
  var chat = document.getElementById('aiChat');
  var fab = document.getElementById('chatFab');
  if (chatOpen) {
    chat.style.display = 'flex';
    fab.style.display = 'none';
    updateQuickActions();
    document.getElementById('chatInput').focus();
  } else {
    chat.style.display = 'none';
    fab.style.display = 'flex';
  }
}

function showChatFab() {
  var fab = document.getElementById('chatFab');
  if (fab) fab.style.display = 'flex';
}

// 3. AZIONI RAPIDE PER RUOLO
function updateQuickActions() {
  var actionsDiv = document.getElementById('aiQuickActions');
  if (!actionsDiv) return;
  var isAdmin = currentUser && currentUser.isAdmin;
  var isGestoreOp = currentUser && currentUser.ruolo === 'Gestore Op.';
  var isAssegnatario = currentUser && currentUser.ruolo === 'Assegnatario';
  var isOspite = currentUser && (currentUser.ruolo === 'Ospite' || currentUser.isGuest);
  var isDriver = currentUser && currentUser.ruolo === 'Driver Aut.';
  var actions = [];
  if (isAdmin || isGestoreOp) {
    actions = [
      { label: '📊 Stato flotta', query: 'stato flotta' },
      { label: '🔧 Officina', query: 'quanti in officina' },
      { label: '🔄 Scorte libere', query: 'scorte disponibili' },
      { label: '📦 In arrivo', query: 'veicoli in arrivo' }
    ];
  } else if (isAssegnatario) {
    actions = [
      { label: '🚗 Miei veicoli', query: 'miei veicoli' },
      { label: '⛽ PIN carburante', query: 'pin carburante' },
      { label: '🔧 Segnala guasto', query: 'come segnalo un guasto' },
      { label: '📋 Scadenze', query: 'scadenze' }
    ];
  } else if (isOspite || isDriver) {
    actions = [
      { label: '🔄 Mio veicolo', query: 'mio veicolo' },
      { label: '🅿 Pool disponibili', query: 'pool disponibili' },
      { label: '⛽ PIN', query: 'pin' },
      { label: '📞 Referente', query: 'contatta referente' }
    ];
  }
  actionsDiv.innerHTML = actions.map(function(a) {
    return '<button onclick="document.getElementById(\'chatInput\').value=\'' + a.query + '\';sendChat()" style="background:var(--surf);border:1px solid var(--border);border-radius:16px;padding:6px 12px;font-size:11px;color:var(--text);cursor:pointer;white-space:nowrap">' + a.label + '</button>';
  }).join('');
}

// 4. INVIO MESSAGGIO
function sendChat() {
  var input = document.getElementById('chatInput');
  var msg = input.value.trim();
  if (!msg) return;
  addMessage('user', msg, 'Tu');
  input.value = '';
  var typingId = addMessage('ai', '✍️ Sto analizzando...', 'Assistente');
  setTimeout(function() {
    var response = getAIResponse(msg);
    var typingEl = document.getElementById(typingId);
    if (typingEl) typingEl.remove();
    addMessage('ai', response, 'Assistente');
    updateQuickActions();
  }, 500);
}

function addMessage(role, text, sender) {
  var id = 'msg_' + Date.now() + '_' + Math.random().toString(36).substr(2,5);
  var div = document.getElementById('chatMessages');
  var isUser = role === 'user';
  var bubble = document.createElement('div');
  bubble.id = id;
  bubble.style.cssText = 'margin:6px 0;padding:10px 14px;border-radius:12px;max-width:90%;font-size:13px;line-height:1.5;white-space:pre-wrap;word-break:break-word;' +
    (isUser ? 'background:var(--acc);color:#0f1923;margin-left:auto;border-bottom-right-radius:4px;font-weight:500' :
               'background:var(--surf2);color:var(--text);margin-right:auto;border-bottom-left-radius:4px');
  var senderEl = document.createElement('div');
  senderEl.style.cssText = 'font-size:9px;color:' + (isUser ? 'rgba(0,0,0,.5)' : 'var(--muted)') + ';margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px';
  senderEl.textContent = sender;
  bubble.appendChild(senderEl);
  bubble.appendChild(document.createTextNode(text));
  div.appendChild(bubble);
  div.scrollTop = div.scrollHeight;
  return id;
}

// 5. CERVELLO AI - RISPOSTE PER RUOLO
function getAIResponse(question) {
  var q = question.toLowerCase().trim();
  var isAdmin = currentUser && currentUser.isAdmin;
  var isGestoreOp = currentUser && currentUser.ruolo === 'Gestore Op.' && currentUser.gestoreOpFlottaOn;
  var isPowerUser = isAdmin || isGestoreOp;
  var ruolo = currentUser ? currentUser.ruolo : 'Assegnatario';
  var myCid = currentUser ? (currentUser.cid || '').toString().trim() : '';
  var mySede = (typeof userSede !== 'undefined' ? userSede : '') ||
                 localStorage.getItem('mf_user_sede_' + (currentUser ? currentUser.cid : '')) || '';

  var n = function(num) { return num === 1 ? '1 veicolo' : num + ' veicoli'; };

  function getMieiVeicoli() {
    var miei = [];
    for (var i = 0; i < FLEET.length; i++) {
      var v = FLEET[i];
      if (cidMatches(v.cid, myCid)) miei.push(v);
      var rt = runtime[v.targa];
      if (rt && rt.assegnato_a && !rt.rilasciato && typeof rt.assegnato_a === 'object' &&
          rt.assegnato_a.cid && cidMatches(rt.assegnato_a.cid, myCid)) {
        if (!miei.find(function(x) { return x.targa === v.targa; })) miei.push(v);
      }
    }
    return miei;
  }

  // ========== RICERCA TARGA ==========
  var targaMatch = q.match(/\b[A-Z]{2}\s?\d{3}\s?[A-Z]{2}\b/i);
  if (targaMatch) {
    var targa = targaMatch[0].replace(/\s/g, '').toUpperCase();
    var v = findVehicle(targa);
    if (!v) return '❌ Targa ' + targa + ' non trovata nella flotta.';
    if (!isPowerUser && ruolo === 'Assegnatario') {
      var miei = getMieiVeicoli();
      if (!miei.find(function(x) { return x.targa === targa; })) {
        return '🔒 Non hai i permessi per visualizzare ' + targa + '. È assegnata a un altro utente.';
      }
    }
    var risposta = '✅ ' + v.targa + '\n';
    risposta += '• Tipo: ' + (v.tipo || 'N/D') + '\n';
    risposta += '• Sede: ' + (v.sede || 'N/D') + '\n';
    risposta += '• Stato: ' + getStato(v) + '\n';
    risposta += '• Pool: ' + (v.pool || 'Assegnata') + '\n';
    if (v.carburante) risposta += '• Carburante: ' + v.carburante + '\n';
    if (v.cognome || v.nome) risposta += '• Assegnatario: ' + [v.cognome, v.nome].filter(Boolean).join(' ') + '\n';
    if (v.pin_eni || v.pin_q8) {
      if (isPowerUser) {
        risposta += '• PIN ENI: ' + (v.pin_eni || '-') + ' | Q8: ' + (v.pin_q8 || '-') + '\n';
      } else {
        var miei = getMieiVeicoli();
        if (miei.find(function(x) { return x.targa === v.targa; })) {
          risposta += '• ⛽ PIN disponibile: usa il pulsante PIN nella card\n';
        }
      }
    }
    return risposta.trim();
  }

  // ========== AMMINISTRATORE / GESTORE OP. ==========
  if (isPowerUser) {
    if (q.indexOf('stato flotta') !== -1 || q.indexOf('riepilogo') !== -1 || q.indexOf('dashboard') !== -1) {
      var marc = FLEET.filter(function(v) { return getStato(v) === 'Marciante'; }).length;
      var off  = FLEET.filter(function(v) { return getStato(v) === 'Officina'; }).length;
      var arr  = FLEET.filter(function(v) { return getStato(v) === 'In arrivo'; }).length;
      var scorteLibere = FLEET.filter(function(v) { return v.pool === 'Scorta' && getStato(v) === 'Marciante' && isLibero(v); }).length;
      return '📊 Stato Flotta\n\n' +
        '✅ Marcianti: ' + marc + '\n' +
        '🔧 In officina: ' + off + '\n' +
        '📦 In arrivo: ' + arr + '\n' +
        '🔄 Scorte libere: ' + scorteLibere + '\n' +
        '📋 Totale: ' + FLEET.length + ' veicoli';
    }
    if (q.indexOf('officina') !== -1 || q.indexOf('guasti') !== -1) {
      var offVehicles = FLEET.filter(function(v) { return getStato(v) === 'Officina'; });
      if (!offVehicles.length) return '✅ Nessun veicolo in officina al momento.';
      var risp = '🔧 ' + n(offVehicles.length) + ' in officina:\n';
      offVehicles.slice(0, 8).forEach(function(v) {
        risp += '• ' + v.targa + ' - ' + (v.sede || 'N/D') + (v.officina ? ' → ' + v.officina : '') + '\n';
      });
      if (offVehicles.length > 8) risp += '...e altri ' + (offVehicles.length - 8) + '.\n';
      return risp.trim();
    }
    if (q.indexOf('scorta') !== -1 && (q.indexOf('libera') !== -1 || q.indexOf('disponibile') !== -1)) {
      var scorte = FLEET.filter(function(v) { return v.pool === 'Scorta' && getStato(v) === 'Marciante' && isLibero(v); });
      if (!scorte.length) return '⚠️ Nessuna scorta libera disponibile.';
      var bySede = {};
      scorte.forEach(function(v) {
        var s = v.sede || 'N/D';
        if (!bySede[s]) bySede[s] = [];
        bySede[s].push(v);
      });
      var risp = '🔄 ' + n(scorte.length) + ' scorte libere:\n';
      Object.keys(bySede).forEach(function(sede) {
        risp += '\n📍 ' + sede + ' (' + bySede[sede].length + '):\n';
        bySede[sede].forEach(function(v) { risp += '  • ' + v.targa + ' - ' + (v.tipo || 'N/D') + '\n'; });
      });
      return risp.trim();
    }
    if (q.indexOf('in arrivo') !== -1 || q.indexOf('arrivo') !== -1) {
      var arrVehicles = FLEET.filter(function(v) { return getStato(v) === 'In arrivo'; });
      if (!arrVehicles.length) return '📦 Nessun veicolo in arrivo.';
      var risp = '📦 ' + n(arrVehicles.length) + ' in arrivo:\n';
      arrVehicles.forEach(function(v) { risp += '• ' + v.targa + ' - ' + (v.sede || 'N/D') + ' - ' + (v.tipo || 'N/D') + '\n'; });
      return risp.trim();
    }
    if (q.indexOf('sede') !== -1 || q.indexOf('palermo') !== -1 || q.indexOf('trapani') !== -1 || q.indexOf('agrigento') !== -1) {
      var searchSede = ['palermo','trapani','agrigento','caltanissetta','sciacca','bagheria'].find(function(s) { return q.indexOf(s) !== -1; }) || '';
      if (searchSede) {
        var sedeVehicles = FLEET.filter(function(v) { return (v.sede || '').toLowerCase().indexOf(searchSede) !== -1; });
        if (!sedeVehicles.length) return '📍 Nessun veicolo trovato a ' + searchSede.charAt(0).toUpperCase() + searchSede.slice(1) + '.';
        var marc = sedeVehicles.filter(function(v) { return getStato(v) === 'Marciante'; }).length;
        var off  = sedeVehicles.filter(function(v) { return getStato(v) === 'Officina'; }).length;
        return '📍 ' + searchSede.charAt(0).toUpperCase() + searchSede.slice(1) + ': ' + n(sedeVehicles.length) + '\n✅ Marcianti: ' + marc + '\n🔧 Officina: ' + off;
      }
    }
  }

  // ========== ASSEGNATARIO ==========
  if (ruolo === 'Assegnatario' && !isAdmin) {
    if (q.indexOf('miei') !== -1 || q.indexOf('mio veicolo') !== -1) {
      var miei = getMieiVeicoli();
      if (!miei.length) return '🚗 Non hai veicoli assegnati al momento.';
      var risp = '🚗 I tuoi veicoli (' + miei.length + '):\n';
      miei.forEach(function(v) {
        var st = getStato(v);
        var emoji = st === 'Marciante' ? '✅' : st === 'Officina' ? '🔧' : '📦';
        risp += '• ' + emoji + ' ' + v.targa + ' - ' + (v.tipo || 'N/D') + ' (' + st + ')\n';
      });
      return risp.trim();
    }
    if (q.indexOf('pin') !== -1 || q.indexOf('carburante') !== -1) {
      var miei = getMieiVeicoli();
      var conPin = miei.filter(function(v) { return v.pin_eni || v.pin_q8; });
      if (!conPin.length) return '⛽ Nessun PIN carburante disponibile per i tuoi veicoli.';
      var risp = '⛽ PIN Carburante:\n';
      conPin.forEach(function(v) {
        risp += '• ' + v.targa + ': ENI ' + (v.pin_eni || '-') + ' | Q8 ' + (v.pin_q8 || '-') + '\n';
      });
      return risp.trim();
    }
    if (q.indexOf('scaden') !== -1 || q.indexOf('revisione') !== -1 || q.indexOf('noleggio') !== -1) {
      var miei = getMieiVeicoli();
      var conScadenze = miei.filter(function(v) { return v.scad_revisione || v.fine_noleggio; });
      if (!conScadenze.length) return '📋 Nessuna scadenza imminente per i tuoi veicoli.';
      var risp = '📋 Scadenze:\n';
      conScadenze.forEach(function(v) {
        if (v.scad_revisione) {
          var d = new Date(v.scad_revisione);
          var gg = Math.ceil((d - new Date()) / 86400000);
          risp += '• ' + v.targa + ': Revisione ' + (typeof displayDate === 'function' ? displayDate(v.scad_revisione) : v.scad_revisione) + ' ' + (gg < 0 ? '🔴 SCADUTA' : gg <= 30 ? '🟡 tra ' + gg + 'gg' : '✅') + '\n';
        }
        if (v.fine_noleggio) {
          var d = new Date(v.fine_noleggio);
          var gg = Math.ceil((d - new Date()) / 86400000);
          risp += '• ' + v.targa + ': Noleggio ' + (typeof displayDate === 'function' ? displayDate(v.fine_noleggio) : v.fine_noleggio) + ' ' + (gg < 0 ? '🔴 SCADUTO' : gg <= 30 ? '🟡 tra ' + gg + 'gg' : '✅') + '\n';
        }
      });
      return risp.trim();
    }
  }

  // ========== OSPITE / DRIVER ==========
  if (ruolo === 'Ospite' || (currentUser && currentUser.isGuest) || ruolo === 'Driver Aut.') {
    if (q.indexOf('mio') !== -1 && q.indexOf('veicolo') !== -1) {
      var miei = getMieiVeicoli();
      if (!miei.length) return '🚗 Non hai veicoli in carico al momento. Usa i pulsanti in basso per prenotare un veicolo dai pool.';
      var risp = '🚗 Veicolo in carico:\n';
      miei.forEach(function(v) {
        risp += '• ' + v.targa + ' - ' + (v.tipo || 'N/D') + '\n';
        if (v.pin_eni || v.pin_q8) risp += '  ⛽ PIN disponibile nella card veicolo\n';
      });
      return risp.trim();
    }
    if (q.indexOf('pool') !== -1 || q.indexOf('disponibili') !== -1) {
      if (mySede) {
        var scorte  = FLEET.filter(function(v) { return v.pool === 'Scorta'   && v.sede === mySede && getStato(v) === 'Marciante' && isLibero(v); });
        var speciali = FLEET.filter(function(v) { return v.pool === 'Speciali' && v.sede === mySede && getStato(v) === 'Marciante'; });
        var tecnici  = FLEET.filter(function(v) { return v.pool === 'Tecnico'  && v.sede === mySede && getStato(v) === 'Marciante'; });
        return '🅿 Pool a ' + mySede + ':\n' +
          '🔄 Scorta: ' + scorte.length + ' disponibili\n' +
          '⭐ Speciali: ' + speciali.length + '\n' +
          '👷 Tecnici: ' + tecnici.length + '\n\n' +
          'Usa i pulsanti in basso per prenotare.';
      }
      return '📍 Seleziona prima una sede per vedere i pool disponibili.';
    }
    if (q.indexOf('referente') !== -1 || q.indexOf('contatta') !== -1) {
      if (typeof getReferente === 'function') {
        var ref = getReferente(mySede || 'Palermo');
        if (ref) return '📞 Referente:\n' + ref.nome + '\n📱 ' + ref.tel;
      }
      return '⚠️ Referente non configurato per questa sede.';
    }
  }

  // ========== DOMANDE COMUNI ==========
  if (q.indexOf('come') !== -1 && q.indexOf('segnal') !== -1 && q.indexOf('guasto') !== -1) {
    return '🔧 Come segnalare un guasto:\n\n' +
      '1️⃣ Nella card del veicolo, clicca 🔧 Segnala\n' +
      '2️⃣ Scegli ⚠️ Guasto\n' +
      '3️⃣ Compila descrizione e indica se è bloccante\n' +
      '4️⃣ Se bloccante, scegli una sostitutiva\n' +
      '5️⃣ Riceverai il PIN della sostitutiva\n\n' +
      '📋 Ricorda di compilare il DEN!';
  }
  if (q.indexOf('come') !== -1 && q.indexOf('incidente') !== -1) {
    return '🚨 In caso di incidente:\n\n' +
      '1️⃣ Clicca 🔧 Segnala → 🚨 Incidente\n' +
      '2️⃣ Compila tutti i campi obbligatori\n' +
      '3️⃣ Se bloccante: chiama subito Leasys 800 959 950\n' +
      '4️⃣ Compila il DEN entro 24 ore\n' +
      '5️⃣ Scegli una sostitutiva se disponibile';
  }
  if (q.indexOf('aiuto') !== -1 || q.indexOf('help') !== -1 || q.indexOf('cosa puoi fare') !== -1) {
    if (isPowerUser) {
      return '🤖 Cosa posso fare per te (Admin):\n\n' +
        '• "Stato flotta" - Riepilogo generale\n' +
        '• "Quanti in officina?" - Veicoli fermi\n' +
        '• "Scorte libere" - Disponibilità scorte\n' +
        '• "Cerca targa FC123AB" - Dettaglio veicolo\n' +
        '• "Veicoli in arrivo" - Prossimi arrivi\n' +
        '• "Situazione Palermo" - Dettaglio per sede';
    } else if (ruolo === 'Assegnatario') {
      return '🤖 Cosa posso fare per te:\n\n' +
        '• "Miei veicoli" - Lista veicoli assegnati\n' +
        '• "PIN carburante" - Codici rifornimento\n' +
        '• "Scadenze" - Revisioni e noleggi\n' +
        '• "Come segnalo un guasto?" - Procedura';
    } else {
      return '🤖 Cosa posso fare per te:\n\n' +
        '• "Mio veicolo" - Dettagli veicolo in carico\n' +
        '• "Pool disponibili" - Veicoli prenotabili\n' +
        '• "Contatta referente" - Numeri utili';
    }
  }
  if (q.indexOf('grazi') !== -1 || q.indexOf('ciao') !== -1 || q.indexOf('salve') !== -1) {
    var nomi = currentUser ? [currentUser.nome, currentUser.cognome].filter(Boolean).join(' ') : '';
    return '👋 Ciao' + (nomi ? ' ' + nomi : '') + '! Sono l\'assistente virtuale della flotta Sicilia Ovest. Come posso aiutarti?';
  }

  // ========== FALLBACK ==========
  return '🤔 Non ho capito. Puoi chiedermi:\n\n' +
    '• "Stato flotta" (solo admin)\n' +
    '• "Miei veicoli"\n' +
    '• "Cerca targa FC123AB"\n' +
    '• "Aiuto" per vedere tutte le opzioni';
}

