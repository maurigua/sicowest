function qrFilterRender() {
  var listDiv = document.getElementById('qrVehicleList');
  if (!listDiv) return;
  var q = ((document.getElementById('qrSearchInput') || {}).value || '').trim().toUpperCase();
  var activeFleet = FLEET.filter(function(v){ return v.stato !== 'Ritirata' && v.stato !== 'Ceduta'; });
  var filtered = q ? activeFleet.filter(function(v){ return (v.targa||'').includes(q) || ((v.nome||'') + ' ' + (v.cognome||'')).toUpperCase().includes(q); }) : activeFleet;
  listDiv.innerHTML = '';
  filtered.forEach(function(v) {
    var card = document.createElement('div');
    card.style.cssText = 'background:var(--surf2);border:1px solid var(--border);border-radius:12px;padding:14px;margin-bottom:10px;display:flex;align-items:center;gap:14px';
    var qrDiv = document.createElement('div');
    qrDiv.style.cssText = 'width:72px;height:72px;flex-shrink:0;background:#fff;border-radius:8px;display:flex;align-items:center;justify-content:center;overflow:hidden';
    var canvas = document.createElement('canvas');
    qrDiv.appendChild(canvas);
    card.appendChild(qrDiv);
    var info = document.createElement('div');
    info.style.cssText = 'flex:1;min-width:0';
    info.innerHTML = '<div style="font-family:\'Barlow Condensed\',sans-serif;font-size:22px;font-weight:800;color:var(--text)">' + (v.targa||'—') + '</div>' +
      '<div style="font-size:12px;color:var(--muted);margin-top:2px">' + ((v.nome||'') + ' ' + (v.cognome||'')).trim() + '</div>' +
      '<div style="font-size:11px;color:var(--muted)">' + (v.marca||'') + ' ' + (v.modello||'') + '</div>';
    card.appendChild(info);
    var dlBtn = document.createElement('button');
    dlBtn.style.cssText = 'padding:8px 10px;border-radius:10px;border:1px solid rgba(56,189,248,.4);background:rgba(56,189,248,.08);color:var(--acc);font-family:\'Barlow Condensed\',sans-serif;font-size:13px;font-weight:700;cursor:pointer;flex-shrink:0';
    dlBtn.textContent = '⬇️';
    dlBtn.title = 'Scarica QR';
    dlBtn.onclick = (function(targa, cvs){ return function(){ qrDownloadSingle(targa, cvs); }; })(v.targa, canvas);
    card.appendChild(dlBtn);
    listDiv.appendChild(card);
    // Genera QR
    if (window.QRCode) {
      QRCode.toCanvas(canvas, v.targa, { width: 72, margin: 1, color: { dark: '#000000', light: '#ffffff' } }, function(err){});
    }
  });
}

function qrDownloadSingle(targa, canvas) {
  var bigCanvas = document.createElement('canvas');
  bigCanvas.width = 300;
  bigCanvas.height = 340;
  var ctx = bigCanvas.getContext('2d');
  ctx.fillStyle = '#ffffff';
  ctx.fillRect(0, 0, 300, 340);
  if (window.QRCode) {
    var tmpCanvas = document.createElement('canvas');
    QRCode.toCanvas(tmpCanvas, targa, { width: 240, margin: 1 }, function(err) {
      if (!err) {
        ctx.drawImage(tmpCanvas, 30, 20);
        ctx.fillStyle = '#000000';
        ctx.font = 'bold 28px Arial, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText(targa, 150, 290);
        ctx.font = '13px Arial, sans-serif';
        ctx.fillStyle = '#666';
        ctx.fillText('FiberCop · SicOvest', 150, 318);
        var a = document.createElement('a');
        a.download = 'QR_' + targa + '.png';
        a.href = bigCanvas.toDataURL('image/png');
        a.click();
      }
    });
  }
}

