function isLibero(v) {
  // PRINCIPIO FONDAMENTALE: Stato='Utilizzatore' nel DB = uso attivo dichiarato (fatto operativo).
  // Un veicolo con statoAuto='Utilizzatore' e' IN USO ATTIVO -> non libero (salvo rilascio runtime).
  var rt = runtime[v.targa];
  if (rt && rt.rilasciato === true) return true;
  if (rt && rt.assegnato_a && !rt.rilasciato) return false;
  // Stato DB = 'Utilizzatore': uso attivo dichiarato nel DB -> non libero
  var statoAuto = (v.statoAuto || '').trim();
  if (statoAuto === 'Utilizzatore') return false;
  var cogn = (v.cognome || '').trim();
  var nome = (v.nome || '').trim();
  if (cogn || nome) return false;
  var util = (v.utilizzatore || '').trim();
  var pseudo = ['pool scorta', 'pool', 'pool tecnico', 'rittamata', ''];
  if (util && pseudo.indexOf(util.toLowerCase()) === -1) return false;
  return true;
}

