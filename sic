// ---------- FOTOCAMERA QR ----------
function homeOpenCamera() {
  // Permette accesso anche senza DB caricato (veicolo non trovato mostrerà avviso dopo)
  var overlay = document.getElementById('qrScanOverlay');
  overlay.style.display = 'flex';
  var video = document.getElementById('qrVideo');
  navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } })
    .then(function(stream) {
      _v37_qrStream = stream;
      video.srcObject = stream;
      video.play();
      _v37_scanQrFrame();
    })
    .catch(function(err) {
      homeCloseCamera();
      showToast('📷 Fotocamera non disponibile — usa inserimento manuale', true);
    });
}

function homeCloseCamera() {
  if (_v37_qrAnimFrame) { cancelAnimationFrame(_v37_qrAnimFrame); _v37_qrAnimFrame = null; }
  if (_v37_qrStream) { _v37_qrStream.getTracks().forEach(function(t){t.stop();}); _v37_qrStream = null; }
  var video = document.getElementById('qrVideo');
  if (video) video.srcObject = null;
  document.getElementById('qrScanOverlay').style.display = 'none';
}

function _v37_scanQrFrame() {
  var video = document.getElementById('qrVideo');
  var canvas = document.getElementById('qrCanvas');
  if (!video || !canvas) return;
  if (video.readyState === video.HAVE_ENOUGH_DATA) {
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    var ctx = canvas.getContext('2d');
    ctx.drawImage(video, 0, 0);
    var imgData = ctx.getImageData(0, 0, canvas.width, canvas.height);
    if (window.jsQR) {
      var code = jsQR(imgData.data, imgData.width, imgData.height, { inversionAttempts: 'dontInvert' });
      if (code && code.data) {
        homeCloseCamera();
        _v37_onQrScanned(code.data.trim().toUpperCase());
        return;
      }
    }
  }
  _v37_qrAnimFrame = requestAnimationFrame(_v37_scanQrFrame);
}

function _v37_onQrScanned(rawData) {
  // Il QR contiene la targa (es. "EY123BB" o "TARGA:EY123BB")
  var targa = rawData.replace(/^TARGA:/i,'').trim().toUpperCase();
  _v37_showCidModal(targa);
}

