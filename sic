<script>
function openGestioneEP() {
  renderEPList();
  showOverlay('ovGestioneEP');
}

function renderEPList() {
  var q = (document.getElementById('epSearch') ? document.getElementById('epSearch').value.trim().toLowerCase() : '');
  var list = EP_LIST.filter(function(e) {
    if (!q) return true;
    return ((e.targa||'') + ' ' + (e.cognome||'') + ' ' + (e.nome||'')).toLowerCase().indexOf(q) !== -1;
  });
  var cnt = document.getElementById('epCount');
  if (cnt) cnt.textContent = EP_LIST.length + ' veicoli attivi EasyPark' + (q ? ' (filtrati: ' + list.length + ')' : '');
  var html = '';
  if (!list.length) {
    html = '<div style="text-align:center;padding:20px;color:var(--muted);font-size:13px">Nessun veicolo trovato</div>';
  } else {
    for (var i = 0; i < list.length; i++) {
      var e = list[i];
      var nome = ((e.cognome||'') + ' ' + (e.nome||'')).trim() || '—';
      html += '<div style="background:var(--surf2);border:1px solid var(--border);border-radius:8px;padding:12px;display:flex;align-items:center;justify-content:space-between;gap:10px">'
        + '<div><div style="font-family:\'Barlow Condensed\',sans-serif;font-size:18px;font-weight:800;color:#28a745">' + escapeHtml(e.targa) + '</div>'
        + '<div style="font-size:12px;color:var(--muted)">' + escapeHtml(nome) + (e.telefono ? ' · ' + escapeHtml(e.telefono) : '') + '</div></div>'
        + '<div style="display:flex;gap:6px">'
        + '<button onclick="editEPEntry(\'' + escapeHtml(e.targa) + '\')" style="padding:6px 12px;border-radius:4px;border:1px solid rgba(240,165,0,.4);background:rgba(240,165,0,.08);color:var(--acc);font-size:12px;font-weight:700;cursor:pointer">✏️</button>'
        + '<button onclick="deleteEPEntry(\'' + escapeHtml(e.targa) + '\')" style="padding:6px 12px;border-radius:4px;border:1px solid rgba(239,68,68,.4);background:rgba(239,68,68,.08);color:var(--red);font-size:12px;font-weight:700;cursor:pointer">🗑️</button>'
        + '</div></div>';
    }
  }
  var el = document.getElementById('epList');
  if (el) el.innerHTML = html;
}

function openAddEP() {
  document.getElementById('epEntryTitle').textContent = 'Aggiungi EasyPark';
  document.getElementById('epEntryOldTarga').value = '';
  document.getElementById('epEntryTarga').value = '';
  document.getElementById('epEntryCognome').value = '';
  document.getElementById('epEntryNome').value = '';
  document.getElementById('epEntryTel').value = '';
  document.getElementById('epEntryEmail').value = '';
  document.getElementById('ovGestioneEP').style.display = 'none';
  document.getElementById('ovEPEntry').classList.add('open');
}

function editEPEntry(targa) {
  var e = EP_LIST.filter(function(x) { return x.targa === targa; })[0];
  if (!e) return;
  document.getElementById('epEntryTitle').textContent = 'Modifica EasyPark';
  document.getElementById('epEntryOldTarga').value = targa;
  document.getElementById('epEntryTarga').value = e.targa;
  document.getElementById('epEntryCognome').value = e.cognome || '';
  document.getElementById('epEntryNome').value = e.nome || '';
  document.getElementById('epEntryTel').value = e.telefono || '';
  document.getElementById('epEntryEmail').value = e.email || '';
  document.getElementById('ovGestioneEP').style.display = 'none';
  document.getElementById('ovEPEntry').classList.add('open');
}

function saveEPEntry() {
  // [V43] Legal Entity Lock attivo: ENTITY_ID = FIBERCOP_SPA_TEST_ENV
  var targa = document.getElementById('epEntryTarga').value.trim().toUpperCase();
  if (!targa) { showToast('Targa obbligatoria', true); return; }
  var oldTarga = document.getElementById('epEntryOldTarga').value;
  // Rimuovi vecchia entry se esiste
  if (oldTarga) EP_LIST = EP_LIST.filter(function(x) { return x.targa !== oldTarga; });
  // Rimuovi eventuale duplicato stesso targa
  EP_LIST = EP_LIST.filter(function(x) { return x.targa !== targa; });
  EP_LIST.push({
    targa:    targa,
    cognome:  document.getElementById('epEntryCognome').value.trim(),
    nome:     document.getElementById('epEntryNome').value.trim(),
    telefono: document.getElementById('epEntryTel').value.trim(),
    email:    document.getElementById('epEntryEmail').value.trim()
  });
  EP_LIST.sort(function(a,b) { return a.targa.localeCompare(b.targa); });
  saveFleet();
  renderList();
  document.getElementById('ovEPEntry').classList.remove('open');
  document.getElementById('ovGestioneEP').style.display = 'flex';
  renderEPList();
  showToast('EasyPark salvato: ' + targa);
}

function deleteEPEntry(targa) {
  if (!confirm('Rimuovere ' + targa + ' da EasyPark?')) return;
  EP_LIST = EP_LIST.filter(function(x) { return x.targa !== targa; });
  saveFleet();
  renderList();
  renderEPList();
  showToast('Rimosso da EasyPark: ' + targa);
}
</script>

