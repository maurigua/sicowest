  var inOff = FLEET.filter(function(v) { return getStato(v) === 'Officina'; });
  if (inOff.length === 0) html += '<div class="report-empty">Nessun veicolo in officina</div>';
  else {
    for (var i = 0; i < inOff.length; i++) {
      var v = inOff[i];
      html += '<div class="report-card report-card-off"><div class="report-targa">' + v.targa + '</div><div class="report-tipo">' + (v.tipo || '') + '</div><div class="report-row"><span class="report-chip">📍 ' + (v.sede || 'N/D') + '</span></div></div>';
    }
  }
  html += '</div>';
  document.getElementById('reportContent').innerHTML = html;
  showOverlay('ovReport');
}

function confermaSostitutiva() {
  var targa = document.getElementById('sostTargaInput').value.trim().toUpperCase();
  var v = findVehicle(targa);
  if (!v || !currentUser) return;
  if (!runtime[v.targa]) runtime[v.targa] = {};
  runtime[v.targa].assegnato_a = { nome: currentUser.nome || '', cognome: currentUser.cognome || '', cid: currentUser.cid };
  runtime[v.targa].rilasciato = false;
  saveFleet();
  closeAll();
  showToast('Sostitutiva aggiunta: ' + targa);
}

