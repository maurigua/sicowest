// homeDoLogin: login diretto senza passare per loginScreen secondario
function homeDoLogin() {
  var cidEl = document.getElementById('homeCidInput');
  var pinEl = document.getElementById('homePinInput');
  var errEl = document.getElementById('homeLoginErr');
  if (errEl) errEl.style.display = 'none';

  var cid = cidEl ? cidEl.value.trim() : '';
  var pin = pinEl ? pinEl.value.trim() : '';

  if (!cid || !pin) {
    if (errEl) { errEl.textContent = 'Inserisci CID e PIN'; errEl.style.display = 'block'; }
    return;
  }

  // Verifica credenziali direttamente (copia della logica di doLogin)
  var normCid = cid.replace(/^0+/, '');
  var errMsg = '';

  // Super Admin
  if (cid === '1234' && pin === SUPERADMIN_PIN) {
    currentUser = { cid: '1234', cognome: 'Amministratore', nome: '', ruolo: 'SuperAdmin', isAdmin: true, isSuperAdmin: true };
    saveSession(currentUser);
    _bootAfterLogin();
    return;
  }

  // Ospite
  if (pin === GUEST_PIN) {
    currentUser = { cid: 'ospite', cognome: 'Ospite', nome: '', ruolo: 'Ospite', isAdmin: false };
    saveSession(currentUser);
    _bootAfterLogin();
    return;
  }

  // Admin (ADMIN_CIDS)
  if (ADMIN_CIDS.some(function(a){ return cidMatches(a, cid); })) {
    if (pin !== COMPANY_PIN) { errMsg = 'PIN non corretto'; }
    else {
      var pAdmin = CID_LIST.find(function(c){ return cidMatches(c.cid, cid); });
      currentUser = {
        cid: cid,
        cognome: pAdmin ? pAdmin.cognome : '',
        nome: pAdmin ? pAdmin.nome : '',
        ruolo: 'Admin', isAdmin: true, isSuperAdmin: false
      };
      saveSession(currentUser);
      _bootAfterLogin();
      return;
    }
  }

  // Dipendente con PIN aziendale
  if (pin === COMPANY_PIN) {
    var persona = CID_LIST.find(function(p){ return cidMatches(p.cid, cid); });
    if (!persona) { errMsg = 'CID non trovato in anagrafica'; }
    else {
      currentUser = {
        cid: cid,
        cognome: persona.cognome || '',
        nome: persona.nome || '',
        ruolo: persona.ruolo || 'Assegnatario',
        isAdmin: false, isSuperAdmin: false
      };
      saveSession(currentUser);
      _bootAfterLogin();
      return;
    }
  } else if (!errMsg) {
    errMsg = 'PIN non corretto';
  }

  // Errore
  if (errEl) { errEl.textContent = errMsg; errEl.style.display = 'block'; }
  if (pinEl) { pinEl.value = ''; pinEl.focus(); }
}

