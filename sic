  initFleet();
  // Ospite: dopo initFleet (che carica runtime e prenot), controlla se ha già un veicolo in carico
  if (isOspite) {
    var myCidGuest = (currentUser.cid || '').toString().trim();
    var guestHasVehicle = false;
    for (var gi = 0; gi < FLEET.length; gi++) {
      var gv = FLEET[gi];
      if (runtime[gv.targa] && runtime[gv.targa].rilasciato === true) continue;
      var grt = runtime[gv.targa];
      if (grt && grt.assegnato_a && !grt.rilasciato) {
        if (typeof grt.assegnato_a === 'object' && grt.assegnato_a.cid && cidMatches(grt.assegnato_a.cid, myCidGuest)) { guestHasVehicle = true; break; }
      }
      if (isPrenotata(gv.targa) && getPrenot().some(function(p) { return p.targa === gv.targa && cidMatches(p.cid, myCidGuest); })) { guestHasVehicle = true; break; }
    }
    if (guestHasVehicle) {
      _s('poolBtnsGuest', 'none');
      listVisible = true;
      document.getElementById('listPanel').style.display = 'block';
      var tBtnG = document.getElementById('btnToggleList');
      if (tBtnG) { tBtnG.innerHTML = '▲ Nascondi veicoli'; tBtnG.classList.add('open'); }
      renderList();
    }
  }
  // Assegnatario / Gestore Op. switch OFF: apri lista automaticamente se ha veicoli
  if (!isAdmin && !isOspite && !isDriverAut) {
    var autoFiltered = getFilteredForUser(FLEET.filter(function(v) {
      var st = getStato(v);
      return st !== 'Ritirata' && st !== 'Ceduta';
    }));
    if (autoFiltered.length > 0) {
      listVisible = true;
      document.getElementById('listPanel').style.display = 'block';
      var tBtnA = document.getElementById('btnToggleList');
      if (tBtnA) { tBtnA.innerHTML = '▲ Nascondi veicoli'; tBtnA.classList.add('open'); }
      renderList();
    }
  }
  updatePrenotBtn();
}

