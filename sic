function confirmGuestReg(cid) {
  var nome = (document.getElementById('guestNome')||{}).value || '';
  var cognome = (document.getElementById('guestCognome')||{}).value || '';
  var email = (document.getElementById('guestEmail')||{}).value || '';
  var citta = (document.getElementById('guestCitta')||{}).value || '';
  var errEl = document.getElementById('guestRegErr');
  if (!nome.trim() || !cognome.trim() || !email.trim() || !citta) {
    if (errEl) errEl.textContent = 'Compila tutti i campi';
    return;
  }
  var newEntry = { cid: cid, cognome: cognome.trim(), nome: nome.trim(), mail: email.trim(), sede: citta, targa: null, ruolo: 'Ospite' };
  var existing = -1;
  for (var i = 0; i < CID_LIST.length; i++) { if (CID_LIST[i].cid === cid) { existing = i; break; } }
  if (existing >= 0) CID_LIST[existing] = newEntry; else CID_LIST.push(newEntry);
  localStorage.setItem('mf_cid_list', JSON.stringify(CID_LIST));

  currentUser = { cid: cid, nome: nome.trim(), cognome: cognome.trim(), mail: email.trim(), isAdmin: false, isGuest: true, guestCitta: citta, ruolo: 'Ospite' };
  saveSession(currentUser);
  var box = document.getElementById('guestRegBox');
  if (box) box.remove();
  userSede = citta;
  localStorage.setItem('mf_user_sede_' + cid, citta);
  startApp();
}

function postLoginFlow() {
  // [MANTENUTO V42] Flow post-login: ruoli, theme, sezione default
  // Sicurezza assoluta: solo chi è esplicitamente admin può avere isAdmin=true
  if (currentUser && !currentUser.isSuperAdmin && !ADMIN_CIDS.some(function(a){ return cidMatches(a, currentUser.cid); })) {
    currentUser.isAdmin = false;
    if (currentUser.ruolo === 'Admin') currentUser.ruolo = 'Assegnatario';
    saveSession(currentUser);
  }
  if (currentUser.isAdmin) {
    userSede = 'ADMIN';
    localStorage.setItem('mf_user_sede_' + currentUser.cid, 'ADMIN');
    startApp(); return;
  }
  // Non-admin: deriva SEMPRE sede dal veicolo assegnato nel DB (fonte autoritativa)
  var myCid = (currentUser.cid || '').toString().trim();
  var sedeRicavata = '';
  for (var i = 0; i < FLEET.length; i++) {
    var v = FLEET[i];
    if (cidMatches(v.cid, myCid) || cidMatches(v._assegnatario_cid, myCid)) {
      sedeRicavata = (v.sede || '').trim();
      break;
    }
  }
  if (sedeRicavata) {
    userSede = sedeRicavata;
    localStorage.setItem('mf_user_sede_' + myCid, sedeRicavata);
  } else {
    // Fallback a localStorage solo se DB non ha info (CID non trovato in FLEET)
    var savedSede = localStorage.getItem('mf_user_sede_' + myCid);
    userSede = (savedSede && savedSede !== 'ADMIN') ? savedSede : null;
  }
  startApp();
}

function showSedeSelector() {
  var sedi = [];
  var seen = {};
  for (var i = 0; i < FLEET.length; i++) {
    var s = (FLEET[i].sede || '').trim();
    if (s && !seen[s]) { seen[s] = 1; sedi.push(s); }
  }
  sedi.sort();
  if (!sedi.length) sedi = ['Palermo','Trapani','Agrigento','Caltanissetta','Sciacca','Bagheria','Mazara del Vallo'];

  var overlay = document.createElement('div');
  overlay.id = 'sedeSelector';
  overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px';

  var box = document.createElement('div');
