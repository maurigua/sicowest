        v.tipo||'', v.carburante||'',
        v.note||'',
        v.officina||'', v.data_officina||'', v.inizio_noleggio||'', v.fine_noleggio||'',
        v.scad_revisione||'', v.aot||'', v.cle||'', v.pin_eni||'', v.pin_q8||'',
        ztlC, ztlF
      ]);
    }
    var wsDB = XLSX.utils.aoa_to_sheet(dbRows);
    XLSX.utils.book_append_sheet(wb, wsDB, 'DB auto');

    var cancRows = [['Targa','Note','Data cancellazione']];
    for (var j = 0; j < cancelledFleet.length; j++) {
      var c = cancelledFleet[j];
      cancRows.push([c.targa||'', c.note||'', c.deletedAt||'']);
    }
    var wsCanc = XLSX.utils.aoa_to_sheet(cancRows);
    XLSX.utils.book_append_sheet(wb, wsCanc, 'Targhe cancellate');

    var cidRows = [['Cid','cognome','nome','mail','sede','targa','Ruolo']];
    for (var k = 0; k < CID_LIST.length; k++) {
      var cc = CID_LIST[k];
      cidRows.push([cc.cid||'', cc.cognome||'', cc.nome||'', cc.mail||'', cc.sede||'', cc.targa||'', cc.ruolo||'Assegnatario']);
    }
    var wsCid = XLSX.utils.aoa_to_sheet(cidRows);
    XLSX.utils.book_append_sheet(wb, wsCid, 'CID_anagrafica');

    var epRows = [['Nome','Cognome','Telefono','Targa','Email','check']];
    for (var ep = 0; ep < EP_LIST.length; ep++) {
      var e = EP_LIST[ep];
      epRows.push([e.nome||'', e.cognome||'', e.telefono||'', e.targa||'', e.email||'', 'Attivvato']);
    }
    var wsEPout = XLSX.utils.aoa_to_sheet(epRows);
    XLSX.utils.book_append_sheet(wb, wsEPout, 'db EasyPark');

    var today = new Date().toISOString().slice(0,10);
    XLSX.writeFile(wb, 'FlottaSicOvest_' + today + '.xlsx');
    showToast('Esportati: ' + FLEET.length + ' veicoli, ' + cancelledFleet.length + ' cancellate, ' + CID_LIST.length + ' CID');
  }
  if (typeof XLSX === 'undefined') {
    var s = document.createElement('script');
    s.src = 'https://cdn.sheetjs.com/xlsx-latest/package/dist/xlsx.full.min.js';
    s.onload = doExport;
    document.head.appendChild(s);
  } else { doExport(); }
}

function importFleetData() {
  var fi = document.getElementById('fileInput');
  if (fi) { fi.click(); return; }
  var input = document.createElement('input');
  input.type = 'file';
  input.accept = '.xlsx,.xls';
  input.onchange = function(e) {
    var f = e.target.files[0];
    if (!f) return;
    var r = new FileReader();
    r.onload = function(ev) { processExcelData(ev.target.result); };
    r.onerror = function() { showToast('❌ File bloccato da Excel. Chiudi il file in Excel e riprova.', true); };
    r.readAsArrayBuffer(f);
  };
  input.click();
}

function processExcelData(arrayBuffer) {
  try {
    var wb;
    try {
      wb = XLSX.read(arrayBuffer, { type: 'array', cellDates: true });
    } catch(eEnc) {
      // Alcuni file xlsx da OneDrive/Excel risultano "criptati" per SheetJS
      // Tentativo con password vuota
      wb = XLSX.read(arrayBuffer, { type: 'array', cellDates: true, password: '' });
    }

    var wsDB = wb.Sheets['DB auto'] || wb.Sheets['DB'] || wb.Sheets[wb.SheetNames[0]];
    var rowsDB = XLSX.utils.sheet_to_json(wsDB, { defval: '' });
    if (!rowsDB.length) { showToast('Foglio DB vuoto', true); return; }

    // Nessuna MyFleet separata: tutte le colonne sono in "DB auto"
    var myFleetMap = {};

    function fmtDate(v) {
      if (!v) return '';
      if (v instanceof Date) return v.toISOString().slice(0,10);
      var s = v.toString().trim();
      if (s.match(/^\d{4}-\d{2}-\d{2}/)) return s.slice(0,10);
      return s;
    }

    function fr(r, keys) {
      for (var ki = 0; ki < keys.length; ki++) {
        var k = keys[ki];
        if (r[k] !== undefined && r[k] !== null && r[k] !== '') return r[k];
      }
      for (var ki2 = 0; ki2 < keys.length; ki2++) {
        var kl = keys[ki2].toLowerCase();
        for (var rk in r) {
          if (rk.trim().toLowerCase() === kl && r[rk] !== undefined && r[rk] !== null && r[rk] !== '') return r[rk];
        }
      }
      return '';
    }

    var COL_MAP = {
      targa:            ['Targa','targa'],
      tipo:             ['Tipo veicolo','tipo veicolo','tipo'],
      sede:             ['Sede','sede'],
      cognome:          ['Cognome','cognome'],
      nome:             ['Nome','nome'],
      cid:              ['Cid','cid','CID'],
      stato:            ["Stato dell'auto",'stato auto','stato','Stato'],
      pool:             ['Tipologia pool','Tipologia Pool','tipi di pool','pool','Pool'],
      carburante:       ['tipo carburante','Tipo carburante','carburante'],
      note:             ['Promemoria operativo','Note','note'],
      officina:         ['Officina','officina'],
      data_officina:    ['data ingresso officina','data_ingresso_officina'],
      fine_noleggio:    ['data_fine_noleggio_ca','fine_noleggio'],
      inizio_noleggio:  ['data_inizio_noleggio','inizio_noleggio'],
      scad_revisione:   ['scadenza_revisione','Scadenza revisione'],
      aot:              ['AOT Pro op.','AOT','aot'],
      cle:              ['C.le di riferimento pro op.','C.le RICOVERO AUTO','Via c.le veicolo','cle'],
      pin_eni:          ['pin_enilive','pin_eni'],
      pin_q8:           ['pin_q8'],
      ztl_citta:        ['ztl città','ztl citta','ztl_citta'],
      ztl_fine:         ['ztl fine','ztl_fine'],
      ztl_richiesta:    ['ztl richiesta','ztl_richiesta']
    };

    var imported = rowsDB.map(function(row) {

      var targa = fr(row, COL_MAP.targa).toString().trim().toUpperCase();

      var cognome = fr(row, COL_MAP.cognome).toString().trim();
      var nome    = fr(row, COL_MAP.nome).toString().trim();
      var cid     = fr(row, COL_MAP.cid).toString().trim();

      var statoRaw = fr(row, COL_MAP.stato).toString().trim();
      var stato = 'Marciante';
      if (statoRaw === 'Officina') stato = 'Officina';
      else if (statoRaw === 'In arrivo') {
        stato = (cognome || nome || cid) ? 'Marciante' : 'In arrivo';
      }
      else if (statoRaw === 'Ritirata') stato = 'Ritirata';
      else if (statoRaw === 'Ceduta') stato = 'Ceduta';
      else if (statoRaw.indexOf('Marciante') !== -1) stato = 'Marciante';
      // PRINCIPIO FONDAMENTALE: 'Utilizzatore' = uso attivo dichiarato (fatto operativo)
      // 'Assegnata' = veicolo assegnato a persona. Entrambi → marciante operativamente.
      // Il valore raw viene conservato in statoAuto per distinguerli nei conteggi pool.
      else if (statoRaw === 'Utilizzatore' || statoRaw === 'Assegnata') stato = 'Marciante';
      else if (statoRaw) stato = statoRaw;

      var poolRaw = fr(row, COL_MAP.pool).toString().trim();
      var pool = 'Assegnata';
      if (poolRaw === 'Scorta') pool = 'Scorta';
      else if (poolRaw === 'Tecnico') pool = 'Tecnico';
      else if (poolRaw === 'Speciali') pool = 'Speciali';
      else if (poolRaw && poolRaw !== 'In arrivo' && poolRaw !== 'None') pool = poolRaw;

      var richieste = [];
      for (var n = 1; n <= 9; n++) {
        var dr = row['data_richiesta_' + n];
        var tr = row['tipo_richiesta_' + n];
        var dd = row['data_decorrenza_' + n];
        var sr = row['stato_richiesta_' + n];
        var cr = row['codice_richiesta_' + n];
        if (dr || tr || cr) {
          richieste.push({
            data: fmtDate(dr), tipo: (tr||'').toString().trim(),
            decorrenza: fmtDate(dd), stato: (sr||'').toString().trim(),
            codice: (cr||'').toString().trim()
          });
        }
      }

      var ztl = [];
      var ztlC = fr(row, COL_MAP.ztl_citta).toString().trim();
      var ztlF = fmtDate(fr(row, COL_MAP.ztl_fine));
      if (ztlC) {
        // ztl_citta può contenere più città separate da -, /, ,
        var cities = ztlC.split(/\s*[\-–\/,]\s*/);
        var seenCities = {};
        for (var ci = 0; ci < cities.length; ci++) {
          var city = cities[ci].trim();
          if (city && !seenCities[city.toLowerCase()]) {
            seenCities[city.toLowerCase()] = true;
            ztl.push({ citta: city, scadenza: ci === 0 ? ztlF : '' });
          }
        }
      }

      var pinEni = fr(row, COL_MAP.pin_eni).toString().trim().replace('.0','') || null;
      var pinQ8  = fr(row, COL_MAP.pin_q8).toString().trim().replace('.0','') || null;

      return {
        targa:         targa,
        tipo:          fr(row, COL_MAP.tipo).toString().trim(),
        sede:          fr(row, COL_MAP.sede).toString().trim(),
        cognome:       cognome,
        nome:          nome,
        cid:           cid,
        stato:         stato,
        statoAuto:     statoRaw,   // valore raw da col E: 'Marciante/Assegnata', 'Marciante/Utilizzatore', ecc.
        pool:          pool,
        carburante:    fr(row, COL_MAP.carburante).toString().trim(),
        note:          fr(row, COL_MAP.note).toString().trim() || null,
        officina:      fr(row, COL_MAP.officina).toString().trim() || null,
        data_officina: fmtDate(fr(row, COL_MAP.data_officina)),
        fine_noleggio:    fmtDate(fr(row, COL_MAP.fine_noleggio)),
        inizio_noleggio:  fmtDate(fr(row, COL_MAP.inizio_noleggio)),
        scad_revisione:   fmtDate(fr(row, COL_MAP.scad_revisione)),
        aot:              fr(row, COL_MAP.aot).toString().trim() || null,
        cle:              fr(row, COL_MAP.cle).toString().trim() || null,
        pin_eni:          pinEni,
        pin_q8:           pinQ8,
        ztl:              ztl,
        richieste:        richieste
      };
    }).filter(function(v) { return v.targa; });

    if (!imported.length) { showToast('Nessuna targa trovata nel foglio DB', true); return; }

    // PATCH PIN: se il localStorage ha veicoli con pin_q8/pin_eni mancanti,
    // aggiornali con i dati appena letti dall'Excel (senza toccare nient'altro)
    if (FLEET.length) {
      var pinMap = {};
      imported.forEach(function(v) {
        if (v.targa) pinMap[v.targa] = { pin_eni: v.pin_eni, pin_q8: v.pin_q8 };
      });
      FLEET.forEach(function(v) {
        if (pinMap[v.targa]) {
          if (!v.pin_eni && pinMap[v.targa].pin_eni) v.pin_eni = pinMap[v.targa].pin_eni;
          if (!v.pin_q8 && pinMap[v.targa].pin_q8) v.pin_q8 = pinMap[v.targa].pin_q8;
        }
      });
      saveFleet();
    }

    var wsCancSheet = wb.Sheets['Targhe cancellate'];
    var importedCanc = [];
    if (wsCancSheet) {
      var rowsCanc = XLSX.utils.sheet_to_json(wsCancSheet, { defval: '' });
      importedCanc = rowsCanc.map(function(row) {
        return {
          targa:     fr(row, ['Targa','targa']).toString().trim().toUpperCase(),
          deletedAt: fmtDate(fr(row, ['Data cancellazione','Data cancellazione ','deletedAt'])) || '',
          note:      fr(row, ['Note','note']).toString().trim() || null
        };
      }).filter(function(c) { return c.targa; });
      var seen = {};
      importedCanc = importedCanc.filter(function(c) {
        if (seen[c.targa]) return false;
        seen[c.targa] = 1; return true;
      });
    }

    var wsCid = wb.Sheets['CID_anagrafica'];
    if (wsCid) {
      var rowsCid = XLSX.utils.sheet_to_json(wsCid, { defval: '' });
      var oldCidMap = {};
      try {
        var oldCidList = JSON.parse(localStorage.getItem('mf_cid_list') || '[]');
        oldCidList.forEach(function(c) { if (c.cid) oldCidMap[c.cid] = c.ruolo || null; });
      } catch(e) {}
      CID_LIST = rowsCid.map(function(row) {
        var cidVal = fr(row, ['Cid','cid','CID']).toString().trim();
        // Col F ('Profilo operativo') = ruolo reale quando != 'Assegnatario' (es. Gestore Op., Ospite)
        // Col H (unnamed = '__EMPTY_1') = ruolo alternativo per alcuni utenti
        var ruoloF = (fr(row, ['Profilo operativo', 'Profilo']) || '').toString().trim();
        var ruoloH = (row['__EMPTY_1'] || '').toString().trim();
        // Filtra intestazioni spurie in col H
        if (ruoloH === 'Profilo' || ruoloH.length > 30) ruoloH = '';
        var validRoles = ['Assegnatario','Ospite','Driver Aut.','Gestore Op.'];
        // Priorità: col F se ruolo valido != Assegnatario, poi col H, poi Assegnatario
        var ruolo = 'Assegnatario';
        if (validRoles.indexOf(ruoloF) !== -1 && ruoloF !== 'Assegnatario') ruolo = ruoloF;
        else if (validRoles.indexOf(ruoloH) !== -1) ruolo = ruoloH;
        else ruolo = oldCidMap[cidVal] || 'Assegnatario';
        return {
          cid:     cidVal,
          cognome: fr(row, ['cognome','Cognome']).toString().trim(),
          nome:    fr(row, ['nome','Nome']).toString().trim(),
          mail:    fr(row, ['Email','email','Mail']).toString().trim() || null,
          ruolo:   ruolo
        };
      }).filter(function(c) { return c.cid; });
    } else {
      // Fallback: sheet CID_anagrafica assente → ricava CID unici da FLEET (assegnatario/utilizzatore)
      // Normalizza rimuovendo zero iniziali come Excel farebbe
      var cidSeenMap = {};
      FLEET.forEach(function(v) {
        var rawCid = (v.assegnatarioCid || v.utilizzatoreCid || '').toString().trim();
        if (!rawCid) return;
        // Normalizza: rimuovi zeri iniziali per confronto, poi ripristina il formato originale
        var normCid = rawCid.replace(/^0+/, '') || rawCid;
        if (!cidSeenMap[normCid]) {
          cidSeenMap[normCid] = {
            cid:     rawCid,
            cognome: (v.assegnatario || v.utilizzatore || '').toString().trim(),
            nome:    '',
            mail:    null,
            ruolo:   'Assegnatario'
          };
        }
      });
      var existing = {};
      CID_LIST.forEach(function(c){ if(c.cid) existing[c.cid.replace(/^0+/,'')||c.cid] = true; });
      Object.values(cidSeenMap).forEach(function(c){
        var norm = c.cid.replace(/^0+/,'')||c.cid;
        if (!existing[norm]) CID_LIST.push(c);
      });
      console.log('[V43] CID_anagrafica assente: ricavati ' + Object.keys(cidSeenMap).length + ' CID da FLEET');
    }

    var wsEP = wb.Sheets['db EasyPark'] || wb.Sheets['EasyPark'];
    if (wsEP) {
      var rowsEP = XLSX.utils.sheet_to_json(wsEP, { defval: '' });
      var oldEPMap = {};
      EP_LIST.forEach(function(e) { if (e.targa) oldEPMap[e.targa] = e; });
      EP_LIST = rowsEP.map(function(row) {
        var targa = fr(row, ['Targa','targa']).toString().trim().toUpperCase();
        var check = fr(row, ['check','Check']).toString().trim();
        if (!targa || check !== 'Attivvato') return null;
        return {
          targa:    targa,
          nome:     fr(row, ['Nome','nome']).toString().trim(),
          cognome:  fr(row, ['Cognome','cognome']).toString().trim(),
          telefono: fr(row, ['Telefono','telefono']).toString().trim(),
          email:    fr(row, ['Email','email']).toString().trim()
        };
      }).filter(Boolean);
    }

    var ritirati = imported.filter(function(v) { return v.stato === 'Ritirata' || v.stato === 'Ceduta'; });
    FLEET = imported.filter(function(v) { return v.stato !== 'Ritirata' && v.stato !== 'Ceduta'; });
    // Preserva il runtime esistente (stato officina, pool in carico) — non azzerare
    // Rimuovi solo le entry di targhe che non esistono più nella nuova flotta
    var newTarghe = {};
    FLEET.forEach(function(v) { newTarghe[v.targa] = true; });
    Object.keys(runtime).forEach(function(t) { if (!newTarghe[t]) delete runtime[t]; });
    var cancTargheSeen = {};
    importedCanc.forEach(function(c) { cancTargheSeen[c.targa] = true; });
    ritirati.forEach(function(v) {
      if (!cancTargheSeen[v.targa]) {
        importedCanc.push({ targa: v.targa, tipo: v.tipo || '', cid: v.cid || '', note: v.note || null, deletedAt: '' });
        cancTargheSeen[v.targa] = true;
      }
    });
    cancelledFleet = importedCanc;
    saveFleet();
    showToast('Importati: ' + FLEET.length + ' veicoli, ' + cancelledFleet.length + ' cancellate, ' + CID_LIST.length + ' CID, ' + EP_LIST.length + ' EasyPark');
  } catch(err) { showToast('Errore Excel: ' + err.message, true); }
}

