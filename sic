function getGuestTokens() { try { return JSON.parse(localStorage.getItem(GUEST_TOKEN_KEY) || '[]'); } catch(e) { return []; } }
function saveGuestTokens(list) { localStorage.setItem(GUEST_TOKEN_KEY, JSON.stringify(list)); }
function generateToken() { var chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789'; var t = ''; for (var i = 0; i < 4; i++) t += chars[Math.floor(Math.random() * chars.length)]; t += '-'; for (var i = 0; i < 4; i++) t += chars[Math.floor(Math.random() * chars.length)]; return t; }
