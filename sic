  var html = '';
  for (var i = 0; i < tokens.length; i++) {
    if (tokens[i].revoked) continue;
    html += '<div class="token-card"><div><div class="token-card-code">' + tokens[i].code + '</div><div class="token-card-note">' + (tokens[i].nome ? 'Usato da: ' + tokens[i].nome : 'Non ancora usato') + '</div></div><button class="token-revoke-btn" onclick="adminRevokeToken(\'' + tokens[i].code + '\')">❌ Revoca</button></div>';
  }
  listEl.innerHTML = html || '<div style="text-align:center;color:var(--muted);padding:16px">Tutti i token sono stati revocati</div>';
}
function adminGeneraToken() {
  var tokens = getGuestTokens();
  var code = generateToken();
  while (tokens.some(function(t) { return t.code === code && !t.revoked; })) code = generateToken();
  tokens.push({ code: code, nome: '', revoked: false, createdAt: new Date().toISOString() });
  saveGuestTokens(tokens);
  renderTokenList();
  showToast('Token creato: ' + code);
}
function adminRevokeToken(code) {
  var tokens = getGuestTokens();
  tokens = tokens.map(function(t) { if (t.code === code) t.revoked = true; return t; });
  saveGuestTokens(tokens);
  renderTokenList();
  showToast('Token revocato');
}

