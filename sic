// ─── GESTIONE ALLEGATI ADMIN ───────────────────────────────────────────────

function openAllegatiAdmin() {
  if (!currentUser || !currentUser.isAdmin) { showToast('Accesso riservato', true); return; }
  var el = document.getElementById('allegatiSearch');
  if (el) el.value = '';
  renderAllegati();
  showOverlay('ovAllegati');
  // aggiorna badge tab
  updateAllegatiBadge();
}

function updateAllegatiBadge() {
  var badge = document.getElementById('bnAllegBadge');
  if (!badge) return;
  var count = 0;
  (FLEET || []).forEach(function(v){ if (v.docs && v.docs.length) count++; });
  if (count > 0) { badge.textContent = count; badge.style.display = 'flex'; }
  else { badge.style.display = 'none'; }
}

function renderAllegati() {
  var listEl  = document.getElementById('allegatiList');
  var statEl  = document.getElementById('allegatiStat');
  var query   = (document.getElementById('allegatiSearch') ? document.getElementById('allegatiSearch').value.trim().toLowerCase() : '');
  if (!listEl) return;

  // Raccogli tutti i veicoli con almeno un documento
  var conDocs = (FLEET || []).filter(function(v) { return v.docs && v.docs.length > 0; });

  // Filtra per query
  if (query) {
    conDocs = conDocs.filter(function(v) {
      var targa    = (v.targa || '').toLowerCase();
      var assegn   = ((v.cognome || '') + ' ' + (v.nome || '')).toLowerCase();
      var docNames = (v.docs || []).map(function(d){ return (d.name || '').toLowerCase(); }).join(' ');
      var sede     = (v.sede || '').toLowerCase();
      return targa.indexOf(query) > -1 || assegn.indexOf(query) > -1 || docNames.indexOf(query) > -1 || sede.indexOf(query) > -1;
    });
  }

  // Statistiche
  var totDocs = 0;
  conDocs.forEach(function(v){ totDocs += (v.docs || []).length; });
  if (statEl) {
    if (conDocs.length === 0) {
      statEl.textContent = query ? 'Nessun risultato' : 'Nessun allegato presente';
    } else {
      statEl.textContent = conDocs.length + ' veicol' + (conDocs.length === 1 ? 'o' : 'i') + ' · ' + totDocs + ' document' + (totDocs === 1 ? 'o' : 'i');
    }
  }

  if (conDocs.length === 0) {
    listEl.innerHTML = '<div style="text-align:center;padding:30px 0;color:var(--muted)"><div style="font-size:36px;margin-bottom:8px">📂</div><div style="font-size:13px">' + (query ? 'Nessun risultato per "' + escapeHtml(query) + '"' : 'Nessun documento allegato ai veicoli') + '</div></div>';
    return;
  }

  // Ordina per targa
  conDocs.sort(function(a, b){ return (a.targa || '').localeCompare(b.targa || ''); });

  var html = '';
  conDocs.forEach(function(v) {
    var targa   = v.targa || '—';
    var assegn  = ((v.cognome || '') + ' ' + (v.nome || '')).trim() || '—';
    var sede    = v.sede || '';
    var docs    = v.docs || [];

    html += '<div style="background:var(--surf2);border:1px solid var(--border);border-radius:10px;padding:12px 14px;margin-bottom:10px">';
    // Header veicolo
    html += '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">';
    html += '<div>';
    html += '<span style="font-family:\'Barlow Condensed\',sans-serif;font-size:20px;font-weight:800;color:var(--acc)">' + escapeHtml(targa) + '</span>';
    if (sede) html += ' <span style="font-size:10px;color:var(--muted);margin-left:6px">' + escapeHtml(sede) + '</span>';
    html += '<div style="font-size:11px;color:var(--muted);margin-top:2px">👤 ' + escapeHtml(assegn) + '</div>';
    html += '</div>';
    html += '<span style="background:rgba(59,130,246,.15);color:var(--blue);border:1px solid rgba(59,130,246,.3);border-radius:4px;font-size:10px;font-weight:700;padding:2px 8px">' + docs.length + ' PDF</span>';
    html += '</div>';

    // Lista documenti
    docs.forEach(function(doc, idx) {
      var fname = doc.name || 'documento_' + (idx + 1);
      var fdate = doc.date || '';
      html += '<div style="display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--border)">';
      html += '<span style="font-size:16px;flex-shrink:0">📄</span>';
      html += '<span style="flex:1;font-size:12px;font-family:monospace;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + escapeHtml(fname) + '</span>';
      if (fdate) html += '<span style="font-size:10px;color:var(--muted);flex-shrink:0">' + escapeHtml(fdate) + '</span>';
      html += '<button onclick="allegatiViewDoc(\'' + escapeHtml(targa) + '\',' + idx + ')" style="font-size:10px;font-weight:700;padding:4px 10px;border-radius:0;border:none;cursor:pointer;background:rgba(59,130,246,.15);color:var(--blue);flex-shrink:0">Apri</button>';
      html += '<button onclick="allegatiDeleteDoc(\'' + escapeHtml(targa) + '\',' + idx + ')" style="font-size:10px;font-weight:700;padding:4px 10px;border-radius:0;border:none;cursor:pointer;background:rgba(239,68,68,.12);color:var(--red);flex-shrink:0">Elimina</button>';
      html += '</div>';
    });

    // Pulsante aggiungi da questa vista
    html += '<div style="margin-top:8px">';
    html += '<input type="file" id="allegAdd_' + escapeHtml(targa) + '" accept=".pdf" style="display:none" onchange="allegatiAddDoc(\'' + escapeHtml(targa) + '\',this)">';
    html += '<button onclick="document.getElementById(\'allegAdd_' + escapeHtml(targa) + '\').click()" style="width:100%;padding:7px;border-radius:0;border:1px dashed rgba(240,165,0,.4);background:transparent;color:var(--acc);font-family:\'Barlow Condensed\',sans-serif;font-size:13px;font-weight:700;cursor:pointer;margin-top:2px">+ Aggiungi PDF</button>';
    html += '</div>';

    html += '</div>';
  });

  listEl.innerHTML = html;
}

function allegatiViewDoc(targa, idx) {
  var v = findVehicle(targa);
  if (!v || !v.docs || !v.docs[idx]) return;
  var w = window.open('', '_blank');
  w.document.write('<iframe src="' + v.docs[idx].data + '" style="width:100%;height:100vh;border:none"></iframe>');
}

function allegatiDeleteDoc(targa, idx) {
  if (!confirm('Eliminare questo documento da ' + targa + '?')) return;
  var v = findVehicle(targa);
  if (!v || !v.docs) return;
  v.docs.splice(idx, 1);
  saveFleet();
  showToast('Documento eliminato');
  renderAllegati();
  updateAllegatiBadge();
}

function allegatiAddDoc(targa, input) {
  if (!input.files || !input.files[0]) return;
  var f = input.files[0];
  var v = findVehicle(targa);
  if (!v) return;
  if (!v.docs) v.docs = [];
  var reader = new FileReader();
  reader.onload = function(e) {
    var today = new Date().toISOString().slice(0,10);
    v.docs.push({ name: f.name, date: today, data: e.target.result });
    saveFleet();
    showToast('PDF aggiunto a ' + targa);
    renderAllegati();
    updateAllegatiBadge();
  };
  reader.readAsDataURL(f);
  input.value = '';
}
</script>

